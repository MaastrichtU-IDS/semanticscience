   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://purl.org/spar/cito/"
   xmlns:ns2="http://schema.org/"
   xmlns:ns3="http://semanticscience.org/resource/"
   xmlns:ns4="http://protege.stanford.edu/plugins/owl/protege#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000589">
    <dcterms:alternative xml:lang="en">regulation</dcterms:alternative>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000593"/>
    <rdfs:label xml:lang="en">regulating</rdfs:label>
    <dcterms:description xml:lang="en">regulating is a process that modulates the attributes of an object or process.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000863">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:alternative>sad</dcterms:alternative>
    <dcterms:alternative>unhappiness</dcterms:alternative>
    <dcterms:alternative>unhappy</dcterms:alternative>
    <dcterms:description xml:lang="en">sadness is emotional pain associated with, or characterized by feelings of disadvantage, loss, despair, helplessness, sorrow, and rage.</dcterms:description>
    <rdfs:label xml:lang="en">sadness</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000850">
    <rdfs:label xml:lang="en">joy</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000840"/>
    <dcterms:description xml:lang="en">joy is an emotion of intense happiness.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000851">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <dcterms:description xml:lang="en">loathing is an intense dislike or disgust.</dcterms:description>
    <rdfs:label xml:lang="en">loathing</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001007">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000999"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">assay</rdfs:label>
    <dcterms:alternative xml:lang="en">bioassay</dcterms:alternative>
    <dcterms:description xml:lang="en">An assay is an investigative (analytic) procedure in laboratory medicine, pharmacology, environmental biology, and molecular biology for qualitatively assessing or quantitatively measuring the presence or amount or the functional activity of a target entity (the analyte) which can be a drug or biochemical substance or a cell in an organism or organic sample.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000848">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdfs:label xml:lang="en">interest</rdfs:label>
    <dcterms:description xml:lang="en">interest is the emotion of wanting to know or learn about something or someone.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000999">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
    <rdfs:label xml:lang="en">procedure</rdfs:label>
    <dcterms:description xml:lang="en">A procedure is a process that attempts to achieve one or more objectives by following an established set of actions.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001076">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000994"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">microarray experiment</rdfs:label>
    <dcterms:description xml:lang="en">A microarray experiment is an experiment that involves a microarray device to measure the expression of one or more genes.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000577">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010284"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">primary active transport, also called direct active transport, directly uses energy to transport molecules across a membrane.</dcterms:description>
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000578"/>
    <rdfs:label xml:lang="en">primary active transport</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000812">
    <dcterms:description xml:lang="en">affection is an emotion characterized with a feeling or type of love for another living thing.</dcterms:description>
    <rdfs:label xml:lang="en">affection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
