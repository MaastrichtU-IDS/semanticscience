    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000559"/>
    <dcterms:description xml:lang="en">molecular complex formation is the process of forming a molecular complex from its constituent parts.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
