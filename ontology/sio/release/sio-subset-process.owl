    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">worry is the emotion characterized by concer over a real or imaginary issue.</dcterms:description>
    <rdfs:label xml:lang="en">worry</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001130">
    <dcterms:description xml:lang="en">A process mediated by a protein that modulates the frequency, rate or extent of translation.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001126"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
