    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-process.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000579">
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000580"/>
    <dcterms:description xml:lang="en">symport enabled secondary active transport is a secondary active transfort in which both ion and molecule are transported in the same direction simultaneously.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000578"/>
