natalia villanueva-rosales</dc:contributor>
    <dc:creator xml:lang="en">Michel Dumontier</dc:creator>
    <dcterms:creator rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://orcid.org/0000-0003-4727-9435</dcterms:creator>
    <dcterms:description xml:lang="en">The semanticscience integrated ontology (SIO) provides a simple, integrated ontology (types, relations) for objects, processes and their attributes.

This project provides foundational support for the Bio2RDF (http://bio2rdf.org) and SADI (http://sadiframework.org) projects. 

website: http://semanticscience.org
email: sio-ontology@googlegroups.com
mailing list: http://groups.google.com/group/sio-ontology
</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2010-03-29</dcterms:issued>
    <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:rights>free to use,share,modify. modify with attribution [http://creativecommons.org/licenses/by/4.0/].</dcterms:rights>
    <dcterms:title xml:lang="en">Semanticscience Integrated Ontology (SIO)</dcterms:title>
    <ns1:citesAsAuthority rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.jbiomedsem.com/content/5/1/14</ns1:citesAsAuthority>
    <vann:preferredNamespacePrefix xml:lang="en">sio</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>http://semanticscience.org/resource/</vann:preferredNamespaceUri>
    <ns2:comment>general class inclusion axioms:
'is part of' some 'physical entity' subClassOf 'is located in' some 'physical entity'

role chains:
'has capability' o 'is realized in' -&gt; 'is participant in'</ns2:comment>
    <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://sio.semanticscience.org</rdfs:seeAlso>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-01</dcterms:modified>
    <dc:identifier>sio.owl</dc:identifier>
    <owl:versionInfo>sio-subset-relations.owl</owl:versionInfo>
    <owl:versionIRI rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000710">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000709"/>
    <rdfs:label xml:lang="en">is mutual role of</rdfs:label>
    <dcterms:description xml:lang="en">a is mutual role of b if and only if the realization of role  a necessarily causes the realization of role b.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000288">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000203"/>
    <rdfs:label xml:lang="en">is covalently connected to (transitive)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000553">
    <rdfs:label xml:lang="en">is parameter in</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000231"/>
    <dcterms:description xml:lang="en">is parameter in is a relation between a data item and some data transformation process.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000424">
    <rdfs:label xml:lang="en">is narrower than (t)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#broaderTransitive</ns3:equivalentTo>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000283"/>
    <dcterms:description xml:lang="en">A is narrower than B (t) iff for A is narrower than B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001096">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001097"/>
    <skos:example xml:lang="en">a weather forecast for the city of London produced at a specific time is a specialization of a weather forecast for the city of London.</skos:example>
    <dcterms:description xml:lang="en">is specialization of is a relation between a more specific instance (in terms of spatial/temporal localization &amp; other attributres) than the other.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <ns3:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.w3.org/ns/prov#specializationOf</ns3:equivalentTo>
    <rdfs:label xml:lang="en">is specialization of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000218">
    <rdfs:label xml:lang="en">is quality of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000224"/>
    <dcterms:description xml:lang="en">is quality of is a relation between a quality and the entity that it is a property of.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000641">
    <rdfs:label xml:lang="en">has basis</rdfs:label>
    <dcterms:description xml:lang="en">has basis is a relation between a realizable entity and the quality that forms the basis for it.</dcterms:description>
    <skos:example xml:lang="en">the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization).</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000642"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000334">
    <dcterms:description xml:lang="en">is covalently connected to is a relation between an atom and another atom.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is covalently connected to</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000652"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000288"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000655">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000657"/>
    <rdfs:label xml:lang="en">transforms into</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <dcterms:description xml:lang="en">A transitive temporal relation in which an entity mainstains identity from one state to another.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000229">
    <rdfs:label xml:lang="en">has output</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">has output is a relation between an process and an entity, where the entity is present at the end of the process.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000232"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000221">
    <ns3:subset>core</ns3:subset>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000222"/>
    <dcterms:description xml:lang="en">has unit is a relation between a quantity and the unit it is a multiple of.</dcterms:description>
    <rdfs:label xml:lang="en">has unit</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000205">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000210"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000212"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is represented by</rdfs:label>
    <dcterms:description xml:lang="en">is represented by: a relation between an entity and some symbol.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000630">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010302"/>
    <rdfs:label xml:lang="en">is paralogous to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <dcterms:description xml:lang="en">is paralogous to is a relation between two entities which indicates their common ancestry as a result of a gene duplication.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000736">
    <dcterms:description xml:lang="en">is comparable to is a relation between two entities that share at least one feature whose value can be compared.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is comparable to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000223">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has property is a relation between an entity and the quality, capability or role that it and it alone bears.</dcterms:description>
    <skos:example xml:lang="en">michel's hair has the quality of being brown in colour.</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:label xml:lang="en">has property</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000224"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000068">
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <ns3:equivalentTo>OBO_REL:part_of</ns3:equivalentTo>
    <dcterms:description xml:lang="en">is part of is a transitive, reflexive and anti-symmetric mereological relation between a whole and itself or a part and its whole.</dcterms:description>
    <rdfs:label xml:lang="en">is part of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000061"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010302">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <dcterms:description xml:lang="en">a relation between two entities which indicates their common ancestry.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <rdfs:label xml:lang="en">is homologous to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000312">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
    <dcterms:description xml:lang="en">has product is a relation between an process and an entity, where a new entity exists at the end of the process.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has product</rdfs:label>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000338">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A relation between an information content entity and a product that it (directly/indirectly) specifies</dcterms:description>
    <rdfs:label xml:lang="en">specifies</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000563"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000243"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000339"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000216">
    <dcterms:description xml:lang="en">has measurement value is a relation between a quality/realizable and a measurement value.</dcterms:description>
    <rdfs:label xml:lang="en">has measurement value</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000735">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <dcterms:description xml:lang="en">is lesser than to is a comparison relation between two quantities in which the first has a value smaller than the second.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000733"/>
    <rdfs:label xml:lang="en">is lesser than</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000249">
    <rdfs:label xml:lang="en">is preceded by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <ns3:equivalentTo>OBO_REL:preceded_by</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000128">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000061"/>
    <ns3:equivalentTo>OBO_REL:contained_in</ns3:equivalentTo>
    <ns3:subset>core</ns3:subset>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000202"/>
    <dcterms:description xml:lang="en">A is contained in B iff the spatial region occupied by A is part of the spatial region occupied by B and A is not part of B. [T]</dcterms:description>
    <rdfs:label xml:lang="en">is contained in</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000203">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>nlp</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <dcterms:description xml:lang="en">A is connected to B iff there exists a fiat, material or temporal path between A and B. [S][T]</dcterms:description>
    <dcterms:alternative xml:lang="en">interacts with</dcterms:alternative>
    <rdfs:label xml:lang="en">is connected to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010082">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_010083"/>
    <skos:example xml:lang="en">RNA is translated into Protein</skos:example>
    <skos:example xml:lang="en">a relation between two information content entities in which one is translated into (a completely different kind of entity) another through some process.</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010078"/>
    <rdfs:label xml:lang="en">is translated into</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000656">
    <dcterms:description xml:lang="en">A  temporal relation in which an entity mainstains identity from one state to another.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000655"/>
    <rdfs:label xml:lang="en">immediately transforms into</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000658"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000008">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:label xml:lang="en">has attribute</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000230">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000231"/>
    <rdfs:label xml:lang="en">has input</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has input is a relation between a process and an entity, where the entity is present at the beginning of the process.</dcterms:description>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000905">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has substrate</rdfs:label>
    <dcterms:description xml:lang="en">has substrate is a relation between a process and an object where the object is destroyed by its participation in the process.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000225">
    <dcterms:description xml:lang="en">has function is the relation between an entity and a function that is ascribed to it.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000226"/>
    <rdfs:label xml:lang="en">has function</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000235"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001155">
    <rdfs:label xml:lang="en">is regulated by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000224">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:label xml:lang="en">is property of</rdfs:label>
    <dcterms:description xml:lang="en">is property of is a relation betweena  quality, capability or role and the entity that it and it alone bears.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000974">
    <dcterms:description xml:lang="en">has ordered part of is a proper part relation in which the part is one of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:label xml:lang="en">has ordered part</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001242">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000736"/>
    <dcterms:description xml:lang="en">is identical to is a relation between two objects that are conceptually the same notwithstanding provenance or other non-intrinsic attributes.</dcterms:description>
    <rdfs:label xml:lang="en">is identical to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000145">
    <dcterms:description xml:lang="en">A is location of B iff the spatialtemporal region occupied by A has the spatialtemporal region occupied by B as a part. [T][R]</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <ns3:subset>nlp+</ns3:subset>
    <rdfs:label xml:lang="en">is location of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000213">
    <rdfs:label xml:lang="en">has concretization</rdfs:label>
    <dcterms:description xml:lang="en">A has concretization B iff A is an informational entity and B is the a quality of some material entity.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000214"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000292">
    <skos:example xml:lang="en">glucose is a target in the hexokinase-mediated conversion of glucose to glucose-6-phosphate.</skos:example>
    <rdfs:label xml:lang="en">is target in</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000231"/>
    <dcterms:description xml:lang="en">is target in is a relation between an entity and a process, where the entity is present at the beginning  of the process and undergoes a change or transformation in the process.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000240">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000203"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">is positionally before</rdfs:label>
    <dcterms:description xml:lang="en">is positionally before is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically less than the projection of the position of the second entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000369">
    <skos:example xml:lang="en">a human has blood as a component part</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000273"/>
    <rdfs:label xml:lang="en">has component part</rdfs:label>
    <dcterms:description xml:lang="en">has component part is a relation between a whole and a component part where the component is instrinsic to the whole, and loss of the part would change the kind that it is.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000339">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000243"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000557"/>
    <dcterms:description xml:lang="en">a relation between a product and the information content entity that specifies it.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is specified by</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000064">
    <rdfs:label xml:lang="en">is provider of</rdfs:label>
    <dcterms:description xml:lang="en">is provider of is a relation between a source and the entity it makes available.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000219"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000066"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000335">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000293"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000652"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">is weakly interacting with</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000254">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000255"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:label xml:lang="en">is annotation of</rdfs:label>
    <dcterms:description xml:lang="en">is annotation of is a relation between some textual entity and the entity that it annotates.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010078">
    <dcterms:description xml:lang="en">A relation between two objects, in which the first object contains information that is used to produce the second object.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000338"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">an open reading frame encodes a protein (it contains information that specifies the amino acid composition and topology)</skos:example>
    <rdfs:label xml:lang="en">encodes</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_010079"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000255">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <dcterms:description xml:lang="en">has annotation is a relation between an entity and some textual anntotation.</dcterms:description>
    <dcterms:alternative xml:lang="en">was annotated with</dcterms:alternative>
    <dcterms:alternative xml:lang="en">is annotated with</dcterms:alternative>
    <skos:example xml:lang="en">document x is annotated with the keywords 'ontology','semantic web'</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has annotation</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000053">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    <rdfs:label xml:lang="en">has proper part</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000093"/>
    <dcterms:description xml:lang="en">has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part.</dcterms:description>
    <skos:example xml:lang="en">a car has an engine as a proper part; a car has a piston as a proper part;</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000495">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <rdfs:label xml:lang="en">is dissimilar to</rdfs:label>
    <dcterms:description xml:lang="en">is dissimilar to is a relation between two entities in which one is considered dissimilar to the other based on some criteria.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000680">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000682"/>
    <rdfs:label xml:lang="en">has start time</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000679"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000250">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000251"/>
    <rdfs:label xml:lang="en">immediately precedes</rdfs:label>
    <dcterms:description xml:lang="en">A non-transitive temporal relation in which one process immediately precedes another process, such that there is no interval of time between the two processes.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000248"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000749">
    <rdfs:label xml:lang="en">is inequal to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000737"/>
    <dcterms:description xml:lang="en">is inequal to is a comparison relation between two quantities whose value are not the same.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001101">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000709"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">a is mutual capability of b if and only if the realization of capability  a necessarily causes the realization of capability b.</dcterms:description>
    <rdfs:label xml:lang="en">is mutual capability of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000323">
    <rdfs:label xml:lang="en">is surrounded by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000128"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000324"/>
    <dcterms:description xml:lang="en">A 'is surrounded by' B iff the A 'is contained by' B and A 'is adjacent to' B or A 'is directly connected to' B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000310">
    <rdfs:label xml:lang="en">is direct part of</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">is direct part of is a relation between a specific part (at some level of granularity) and its whole.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000093"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000658">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is immediately transformed from</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000657"/>
    <dcterms:description xml:lang="en">A  temporal relation in which an entity mainstains identity from one state to another.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000892">
    <rdfs:label xml:lang="en">in relation from</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000212"/>
    <dcterms:description xml:lang="en">a in relation from b is a comparative relation in a is the object of reference in a relation with b. </dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000214">
    <rdfs:label xml:lang="en">is concretization of</rdfs:label>
    <dcterms:description xml:lang="en">A is concretization of B iff A is a quality of a material entity and B is an informational entity.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000628">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:subset>nlp+</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">refers to is a relation between one entity and the entity that it makes reference to.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:label xml:lang="en">refers to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000207">
    <rdfs:label xml:lang="en">is disputed by</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000772"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000209"/>
    <dcterms:description xml:lang="en">has disputing evidence is a relation between a proposition and something that disputes (does not directly support) the truth of the assertion.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000635">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has trigger is a relation between a realizable and the factor that causes it to be realized.</dcterms:description>
    <rdfs:label xml:lang="en">has trigger</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000636"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000634">
    <rdfs:label xml:lang="en">is xenologous to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000558"/>
    <dcterms:description xml:lang="en">a relation between two entities which indicates their common ancestry but due to horizontal gene transfer.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000679">
    <rdfs:label xml:lang="en">has time boundary</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000054"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000352">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is causally related from</rdfs:label>
    <dcterms:description xml:lang="en">a is causally related from b iff there is a causal chain of events from b to a</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000243"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001154">
    <rdfs:label xml:lang="en">regulates</rdfs:label>
    <dcterms:description xml:lang="en">x regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an effect on the frequency, rate or extent of y</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001155"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000672">
    <rdfs:label xml:lang="en">is identifier for</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <dcterms:alternative>identifies</dcterms:alternative>
    <dcterms:description>a relation between an identifier and an entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000096">
    <dcterms:description xml:lang="en">is boundary of is a mereological relation between a boundary located at the periphery of a whole.</dcterms:description>
    <rdfs:label xml:lang="en">is boundary of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000093"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010080">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is transcribed into</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010078"/>
    <skos:example xml:lang="en">DNA is transcribed into RNA</skos:example>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_010081"/>
    <dcterms:description xml:lang="en">a relation between two information content entities in which one is transcribed into (an exact or similar kind) another through some process.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000222">
    <rdfs:label xml:lang="en">is unit of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is unit of is a relation between a unit and a quantity that it is a multiple of.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000356">
    <skos:example xml:lang="en">the role of a patient is realized in medical examination</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
    <rdfs:label xml:lang="en">is realized in</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000709">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">a is mutually related to b if and only if the realization of the relation of a necessarily causes the realization of a relation to b.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:label xml:lang="en">is mutually related to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000973">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is last part of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000975"/>
    <dcterms:description xml:lang="en">is last part of is a proper part relation in which the part is the last of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000490">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000482"/>
    <rdfs:label xml:lang="en">is close match to</rdfs:label>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#closeMatch</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000095">
    <rdfs:label xml:lang="en">is member of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <dcterms:description xml:lang="en">is member of is a mereological relation between a item and a collection.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000274">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000244"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000497"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A is prior version of B iff A is a variant of B and B derives from A.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000286"/>
    <rdfs:label xml:lang="en">is prior version of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000364">
    <ns3:equivalentTo>dc:creator</ns3:equivalentTo>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
    <rdfs:label xml:lang="en">has creator</rdfs:label>
    <skos:example xml:lang="en">the iPhone was created by Apple Inc</skos:example>
    <dcterms:alternative xml:lang="en">was created by</dcterms:alternative>
    <dcterms:alternative xml:lang="en">is created by</dcterms:alternative>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000365"/>
    <dcterms:description xml:lang="en">has creator is a relation between an entity and that which created it.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000901">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is frequency of is a relation between a temporal unit and an object or event</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000215"/>
    <rdfs:label xml:lang="en">is frequency of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000322">
    <rdfs:label xml:lang="en">is spatiotemporally related to</rdfs:label>
    <dcterms:description xml:lang="en">A is spatiotemporally related to B iff A is in the spatial or temporal vicinity of B</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000204">
    <ns3:equivalentTo>OBO_REL:adjacent_to</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:subset>nlp</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is adjacent to</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <dcterms:description xml:lang="en">A is adjacent to B iff there is a small, but non-zero distance between A and B</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001097">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is generalization of</rdfs:label>
    <dcterms:description xml:lang="en">is generalization of is a relation between a more general instance (in terms of spatial/temporal localization &amp; other attributres) than the other.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000210">
    <rdfs:label xml:lang="en">represents</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <dcterms:description xml:lang="en">a represents b when a serves as a sign, symbol or model of b.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000244">
    <rdfs:label xml:lang="en">is derived from</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:equivalentTo>OBO_REL:derives_from</ns3:equivalentTo>
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000245"/>
    <dcterms:description xml:lang="en">A transitive temporal relation in which one entity was materially formed from another non-identical entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001403">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dc:description xml:lang="en">x is associated with y when x and y are logically or statistically related to one another.</dc:description>
    <rdfs:label xml:lang="en">is associated with</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000699">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000733"/>
    <rdfs:label xml:lang="en">is greater than or equal to</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000737"/>
    <dcterms:description xml:lang="en">is greater than or equal to is a comparison relation between two quantities in which the first has a value larger or equal to the second.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000234">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:label xml:lang="en">has implementation</rdfs:label>
    <dcterms:description xml:lang="en">has implementation is a relation between a specification and an implementation that conforms to it.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001401">
    <rdfs:label xml:lang="en">positively regulates</rdfs:label>
    <dc:description xml:lang="en">x positively regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an effect that increases the frequency, rate or extent of y</dc:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_001154"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000563">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <rdfs:label xml:lang="en">describes</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">describes is a relation between one entity and another entity that it provides a description (detailed account of).</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000028">
    <skos:example xml:lang="en">a collection of cars has as a car as a part;a car has an engine as a part; a car has a piston as a part;</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000145"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
    <rdfs:label xml:lang="en">has part</rdfs:label>
    <dcterms:description xml:lang="en">has part is a transitive, reflexive and antisymmetric relation between a whole and itself or a whole and its part.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000211">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000240"/>
    <dcterms:description xml:lang="en">is positionally after is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically greater than the projection of the position of the second entity.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">is positionally after</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000203"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000029">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000679"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000096"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is time boundary of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001156">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001157"/>
    <rdfs:label xml:lang="en">results in</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000139">
    <ns3:equivalentTo>OBO_REL:has_agent</ns3:equivalentTo>
    <dcterms:description xml:lang="en">has agent is a relation between a process and an entity, where the entity is present throughout the process and is a causal participant in the process.</dcterms:description>
    <rdfs:label xml:lang="en">has agent</rdfs:label>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000061">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000145"/>
    <rdfs:label xml:lang="en">is located in</rdfs:label>
    <dcterms:description xml:lang="en">A is located in B iff the spatialtemporial region occupied by A is part of the spatialtemporal region occupied by B. [T][R]</dcterms:description>
    <ns3:equivalentTo>OBO_REL:located_in</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <skos:example xml:lang="en">A parasite in the interior of a person's intestine is located in their intestinal lumen.</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000251">
    <dcterms:description xml:lang="en">A non-transitive temporal relation in which one process is immediately preceded by another process, such that there is no interval of time between the two processes.</dcterms:description>
    <rdfs:label xml:lang="en">is immediately preceded by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000249"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000425">
    <rdfs:label xml:lang="en">is generically related with</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A is generically related with B iff A is an abstract entity or an information content entity and B is a information content entity or a physical entity, respectively.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000586">
    <rdfs:label xml:lang="en">has capability</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000646"/>
    <skos:example xml:lang="en">SIO has the capability to semantically integrate data.</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000644"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has capability is a relation between an entity and the capability that it bears.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000206">
    <dcterms:description xml:lang="en">is supported by is a relation between a proposition and something that supports the truth of the assertion.</dcterms:description>
    <rdfs:label xml:lang="en">is supported by</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000208"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000772"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000363">
    <rdfs:label xml:lang="en">is satisfied by</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000248">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000249"/>
    <rdfs:label xml:lang="en">precedes</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <dcterms:description xml:lang="en">A transitive, temporal relation in which one process precedes (has occured earlier than) another process.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000673">
    <dcterms:description xml:lang="en">has unique identifier is an inverse functional relation between an entity and an identifier that uniquely identifies it.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000671"/>
    <rdfs:label xml:lang="en">has unique identifier</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000674"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001158">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001159"/>
    <rdfs:label xml:lang="en">affects</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000324">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000202"/>
    <rdfs:label xml:lang="en">surrounds</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A 'surrounds' B iff the A 'contains' B and A 'is adjacent to' B or A 'is directly connected to' B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000772">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000631"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000773"/>
    <dcterms:description xml:lang="en">has evidence is a relation between a proposition and something that demonstrates the truth of the assertion.</dcterms:description>
    <rdfs:label xml:lang="en">has evidence</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000235">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000236"/>
    <rdfs:label xml:lang="en">has disposition</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <dcterms:description xml:lang="en">has disposition is the relation between an entity and a disposition that it bears.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000586"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000272">
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">is variant of: a relationship indicating that two entities are different (by some measure), but either achieve the same objectives in different ways or are permutations of one another (temporal, logical or otherwise)</dcterms:description>
    <rdfs:label xml:lang="en">is variant of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000736"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000633">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000205"/>
    <rdfs:label xml:lang="en">is modelled by</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000242">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000240"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000652"/>
    <dcterms:description xml:lang="en">is directly before is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically less than the projection of the position of the second entity, and the entities are adjacent to one another.</dcterms:description>
    <rdfs:label xml:lang="en">is directly before</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000646">
    <rdfs:label xml:lang="en">is capability of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000643"/>
    <dcterms:description xml:lang="en">is capability of is a relation between a capability and the entity that bears it.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000300">
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>relations</ns3:subset>
    <ns3:subset>nlp</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <dcterms:description xml:lang="en">A relation between a informational entity and its actual value (numeric, date, text, etc).</dcterms:description>
    <rdfs:label xml:lang="en">has value</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000557">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000563"/>
    <rdfs:label xml:lang="en">is described by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000212"/>
    <dcterms:description xml:lang="en">is described by is a relation between one entity and another entity that provides a description (detailed account) of it.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000252">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000212"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000631"/>
    <rdfs:label xml:lang="en">is referenced by</rdfs:label>
    <dcterms:description xml:lang="en">is reference for is a relation between a document that provides information about an entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000063">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
    <dcterms:description xml:lang="en">is agent in is a relation between an entity and a process, where the entity is present throughout the process, no permanent material change occurs, and is a causal participant in the process.</dcterms:description>
    <rdfs:label xml:lang="en">is agent in</rdfs:label>
    <skos:example xml:lang="en">hexokinase is an agent in the conversion of glucose to glucose-6-phosphate</skos:example>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000426">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <rdfs:label xml:lang="en">is manifestation of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000054">
    <skos:example xml:lang="en">the surface of an apple is a 2D boundary of the apple.</skos:example>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000096"/>
    <rdfs:label xml:lang="en">has boundary</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has boundary is a mereological relation between a whole and boundary located at its periphery.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000631">
    <rdfs:label xml:lang="en">references</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <dcterms:description xml:lang="en">references is a relation between one entity and the entity that it makes reference to by name, but is not described by it.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:alternative>mentions</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000734">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000735"/>
    <rdfs:label xml:lang="en">is greater than</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000699"/>
    <dcterms:description xml:lang="en">is greater than to is a comparison relation between two quantities in which the first has a value larger than the second.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000277">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000631"/>
    <rdfs:label xml:lang="en">cites</rdfs:label>
    <dcterms:description xml:lang="en">cites is a relation to refer to by way of example, authority or proof.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000278"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000202">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <dcterms:description xml:lang="en">A contains B iff the spatial region occupied by A has the spatial region occupied by B as a part, and B is not part of A. [T]</dcterms:description>
    <rdfs:label xml:lang="en">contains</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000145"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000208">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is supporting evidence for</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000773"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001278">
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is data item in</rdfs:label>
    <dcterms:description>'is data item in' is a relation between an entity that is described or referenced in a dataset.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000681">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000679"/>
    <rdfs:label xml:lang="en">has end time</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000684"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000093">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is proper part of is an asymmetric, irreflexive (normally transitive) relation between a part and its distinct whole.</dcterms:description>
    <rdfs:label xml:lang="en">is proper part of</rdfs:label>
    <ns3:equivalentTo>OBO_REL:proper_part_of</ns3:equivalentTo>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000774">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is refuted by</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000775"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000772"/>
    <dcterms:description xml:lang="en">has evidence is a relation between a proposition and something that refutes (is incompatible with) the truth of the assertion.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000793">
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000687"/>
    <dcterms:description xml:lang="en">measured at is a relation between a measurement value and the time measurement.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">measured at</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000132">
    <ns3:subset>core</ns3:subset>
    <ns3:equivalentTo>OBO_REL:has_participant</ns3:equivalentTo>
    <dcterms:description xml:lang="en">has participant is a relation that describes the participation of the object in the (processual) subject.</dcterms:description>
    <rdfs:label xml:lang="en">has participant</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000668">
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000892"/>
    <rdfs:label xml:lang="en">in relation to</rdfs:label>
    <dcterms:description xml:lang="en">in relation to is a comparative relation to indicate that the instance of the class holding the relation exists in relation to another entity.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000355">
    <rdfs:label xml:lang="en">realizes</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000356"/>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">realizes is a relation between a process and a realizable entity (role, function, disposition).</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001402">
    <dc:description xml:lang="en">x negatively regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an reduced effect on the frequency, rate or extent of y</dc:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_001154"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">negatively regulates</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000247">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000244"/>
    <dcterms:description xml:lang="en">A non-transitive temporal relation in which one entity is immediately derived from a non-identical entity such that there are no intermediate entities between them.</dcterms:description>
    <rdfs:label xml:lang="en">is immediately derived from</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000477">
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#narrower</ns3:equivalentTo>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000422"/>
    <rdfs:label xml:lang="en">is broader than</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001159">
    <rdfs:label xml:lang="en">is affected by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000642">
    <dcterms:description xml:lang="en">is base for is a relation between a quality and the realizable entity that it is the basis for.</dcterms:description>
    <rdfs:label xml:lang="en">is base for</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <skos:example xml:lang="en">the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization).</skos:example>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001279">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description>has phenotype is a relation between an object and an observable/measurable characteristic.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001280"/>
    <rdfs:label xml:lang="en">has phenotype</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000293">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is weakly interacting with is a symmetric relation between two molecular entities (or any part thereof) that are interacting through some weak force (van der waals, hydrogen bonds, electrostatic interactions)</dcterms:description>
    <rdfs:label xml:lang="en">is weakly interacting with (transitive)</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000203"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000325">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <dcterms:description xml:lang="en">A overlaps with B iff there is some C that is part of both A and B. [S][R]</dcterms:description>
    <rdfs:label xml:lang="en">overlaps with</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000643">
    <rdfs:label xml:lang="en">is realizable property of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000224"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000644"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000632">
    <skos:example xml:lang="en">the architect builds a model that represents the building she envisions.</skos:example>
    <dcterms:description xml:lang="en">is model of is a relation between a model (an artifact) and the entity it purports to represent.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000210"/>
    <rdfs:label xml:lang="en">is model of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000633"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001277">
    <rdfs:label xml:lang="en">has data item</rdfs:label>
    <dcterms:description>has data item is a relation between a dataset and any described / referrenced entity.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <ns3:subset>core</ns3:subset>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001278"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000294">
    <rdfs:label xml:lang="en">is causally related to</rdfs:label>
    <dcterms:description xml:lang="en">a is causally related to b iff there is a causal chain of events from a to b</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000243"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000420">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">the story 'war of worlds' is expressed as every language edition of the book 'war of the worlds'</skos:example>
    <rdfs:label xml:lang="en">has expression</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000421"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001404">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dc:description xml:lang="en">x is correlated with y when x holds a statistical relationship with y</dc:description>
    <rdfs:label xml:lang="en">is correlated with</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_001403"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000682">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000029"/>
    <rdfs:label xml:lang="en">is start time of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000246">
    <dcterms:description xml:lang="en">a immediately derives into b if and only if a or some significant part thereof is consumed in the formation of b and there are no identifiable intermediate entities between a and b.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000245"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000247"/>
    <rdfs:label xml:lang="en">immediately derives into</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000422">
    <rdfs:label xml:lang="en">is broader than (t)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000424"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000283"/>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#narrowerTransitive</ns3:equivalentTo>
    <dcterms:description xml:lang="en">A is broader than B (t) iff for A is broader than B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000365">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000219"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is creator of is a relation between a creator and an entity..</dcterms:description>
    <rdfs:label xml:lang="en">is creator of</rdfs:label>
    <dcterms:alternative xml:lang="en">is created by</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010081">
    <rdfs:label xml:lang="en">is transcribed from</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010079"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000697">
    <rdfs:label xml:lang="en">is mutual disposition of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000709"/>
    <dcterms:description xml:lang="en">a is mutual disposition of b if and only if the realization of the disposition  a necessarily causes the realization of the disposition b.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001098">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is alternate of relates two specialized instances.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001098"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <rdfs:label xml:lang="en">is alternate of</rdfs:label>
    <ns3:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.w3.org/ns/prov#alternateOf</ns3:equivalentTo>
    <skos:example xml:lang="en">two weather forecasts for the city of London produced at different times or by different organizations (etc) are alternates of each other, and instances of / specializations of forecasts for the city of London.</skos:example>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000484">
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#exactMatch</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000482"/>
    <rdfs:label xml:lang="en">is exact match to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000245">
    <rdfs:label xml:lang="en">derives into</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000294"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <dcterms:description xml:lang="en">a derives to b if and only if a or some part thereof is consumed in the formation of b.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000644">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:label xml:lang="en">has realizable property</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000223"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000062">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
    <skos:example xml:lang="en">a car is a participant in a car race; glucose is a participant in glycolysis</skos:example>
    <dcterms:description xml:lang="en">is participant in is a relation that describes the participation of the subject in the (processual) object.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is participant in</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000900">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000216"/>
    <dcterms:description xml:lang="en">has frequency is a relation that specifies the occurence of an object or event</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000901"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has frequency</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000236">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000646"/>
    <rdfs:label xml:lang="en">is disposition of</rdfs:label>
    <dcterms:description xml:lang="en">is disposition of is a relation between a disposition and the entity that it is a property of.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000059">
    <rdfs:label xml:lang="en">has member</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <skos:example xml:lang="en">a collection of cars has as a car as a member</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000095"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <dcterms:description xml:lang="en">has member is a mereological relation between a collection and an item.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000684">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000029"/>
    <rdfs:label xml:lang="en">is end time of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000241">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000652"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000211"/>
    <rdfs:label xml:lang="en">is directly after</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is directly after is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically greater than the projection of the position of the second entity, and the entities are adjacent to one another.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000242"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000341">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <dcterms:description xml:lang="en">is manifested as is a relation between an expression and its manifestations.</dcterms:description>
    <skos:example xml:lang="en">the english language version of 'war of the worlds' is manifested as a collection of english language versions of the book.</skos:example>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000426"/>
    <rdfs:label xml:lang="en">is manifested as</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000733">
    <dcterms:description xml:lang="en">is greater than to is a comparison relation between two quantities in which the first has a value smaller or equal to the second.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000737"/>
    <rdfs:label xml:lang="en">is lesser than or equal to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000362">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">satisfies</rdfs:label>
    <dcterms:description xml:lang="en">satisfies is a relation between an entity and the specification or objective that it conforms to.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000363"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010083">
    <rdfs:label xml:lang="en">is translated from</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010079"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000311">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">glucose-6-phosphate is the product of the hexokinase-mediated conversion of glucose to glucose-6-phosphate.</skos:example>
    <dcterms:description xml:lang="en">is product of is a relation between an entity and a process, where the entity is present at the end  of the process as a result of a transformation in the process target.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000232"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000312"/>
    <rdfs:label xml:lang="en">is product of</rdfs:label>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000629">
    <rdfs:label xml:lang="en">is subject of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000557"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000060">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is denoted by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000205"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000972">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has last part</rdfs:label>
    <dcterms:description xml:lang="en">has last part is a proper part relation in which the part is the last of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000974"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000973"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000674">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000672"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is unique identifier for is a relation between an identifier and an entity that it uniquely identifies</dcterms:description>
    <rdfs:label xml:lang="en">is unique identifier for</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000971">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000974"/>
    <rdfs:label xml:lang="en">has first part</rdfs:label>
    <dcterms:description xml:lang="en">has first part is a proper part relation in which the part is the first of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000773">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is evidence for</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000252"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000552">
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdfs:label xml:lang="en">has parameter</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000230"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has parameter is a relation between a process and an information content entity which modulates the behaviour of some participant.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000553"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000657">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">is transformed from</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <dcterms:description xml:lang="en">A transitive temporal relation in which an entity mainstains identity from one state to another.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000636">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is trigger for</rdfs:label>
