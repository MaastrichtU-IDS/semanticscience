    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000421">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">every language edition of 'war of the worlds' are expressions of the story of 'war of the worlds'</skos:example>
    <dcterms:description xml:lang="en">is expression of is a relation between more concrete expression of some conceptualization.</dcterms:description>
    <rdfs:label xml:lang="en">is expression of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000425"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000491">
    <rdfs:label xml:lang="en">is broad match to</rdfs:label>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#broadMatch</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000482"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000496">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000495"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">hot is the opposite of cold; left is opposite of right</skos:example>
    <rdfs:label xml:lang="en">is opposite to</rdfs:label>
    <dcterms:description xml:lang="en">is opposite to is a relation between two entities in which one is diametrically opposed to the other. </dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000217">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000223"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000218"/>
    <rdfs:label xml:lang="en">has quality</rdfs:label>
    <dcterms:description xml:lang="en">has quality is a relation between an entity and the quality that it bears.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000231">
    <skos:example xml:lang="en">glucose and ATP are inputs in the hexokinase-mediated conversion of glucose to glucose-6-phosphate.</skos:example>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is input in is a relation between an entity and a process, where the entity is present at the beginning of the process.</dcterms:description>
    <rdfs:label xml:lang="en">is input in</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000738">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000737"/>
    <dcterms:description xml:lang="en">is equal to is a comparison relation between two quantities whose value are exactly the same.</dcterms:description>
    <rdfs:label xml:lang="en">is equal to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000975">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000093"/>
    <rdfs:label xml:lang="en">is ordered part of</rdfs:label>
    <dcterms:description xml:lang="en">is ordered part of is a proper part relation in which the part is one of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000273">
    <rdfs:label xml:lang="en">has direct part</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has direct part is a relation to specify a part at a particular level of granularity</dcterms:description>
    <skos:example xml:lang="en">a car has an engine as a direct part</skos:example>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000310"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000011">
    <dcterms:description xml:lang="en">is attribute of is a relation that associates an attribute with an entity where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is attribute of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000215">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000216"/>
    <dcterms:description xml:lang="en">is measurement value of is a relation between a value and the entity that it is a measurement of.</dcterms:description>
    <rdfs:label xml:lang="en">is measurement value of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000737">
    <dcterms:description xml:lang="en">is numerically comparable to is a comparison relation between two quantities whose datatype value can be compared.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000736"/>
    <rdfs:label xml:lang="en">is numerically comparable to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000227">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000228"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is role of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000643"/>
    <dcterms:description xml:lang="en">is role of is a relation between a role and the entity that it is a property of.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000212">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A is referred to by B iff B is an informational entity that makes reference to A.</dcterms:description>
    <rdfs:label xml:lang="en">is referred to by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001157">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000352"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is result of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000558">
    <dcterms:description xml:lang="en">is orthologous to is a relation between two biological entities that share a common ancestor and occur in different species.</dcterms:description>
    <rdfs:label xml:lang="en">is orthologous to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010302"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000283">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <dcterms:description xml:lang="en">is similar to is a relation between two entities that share one or more features.</dcterms:description>
    <rdfs:label xml:lang="en">is similar to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000209">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000773"/>
    <rdfs:label xml:lang="en">is disputing evidence for</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000253">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has source is a relation between an entity and another entity from which it stems from.</dcterms:description>
    <rdfs:label xml:lang="en">has source</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
