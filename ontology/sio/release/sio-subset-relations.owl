<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://purl.org/spar/cito/"
   xmlns:ns2="http://schema.org/"
   xmlns:ns3="http://semanticscience.org/resource/"
   xmlns:ns4="http://protege.stanford.edu/plugins/owl/protege#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001280">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <dcterms:description>is phenotype of is a relation between an observable/measurable characteristic and an object.</dcterms:description>
    <rdfs:label xml:lang="en">is phenotype of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000652">
    <rdfs:label xml:lang="en">is directly connected to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000203"/>
    <dcterms:description xml:lang="en">A is directly connected to B iff there exists a path direclty between A and B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000020">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000060"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000210"/>
    <rdfs:label xml:lang="en">denotes</rdfs:label>
    <skos:example xml:lang="en">the symbol '%' denotes a proportion in relation to a whole.</skos:example>
    <dcterms:description xml:lang="en">denotes is a relation between an entity and what it is a sign or indication of, or what specifically means.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000332">
    <dcterms:description xml:lang="en">is about is a relation between an information content entity and the entity that its primary subject.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000563"/>
    <rdfs:label xml:lang="en">is about</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000629"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000970">
    <rdfs:label xml:lang="en">is first part of</rdfs:label>
    <dcterms:description xml:lang="en">is first part of is a proper part relation in which the part is the first of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000975"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000971"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000313">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is component part of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000310"/>
    <dcterms:description xml:lang="en">is component part of is a relation between a component and a whole, where the component is instrinsic to the whole, and loss of the part would change the kind that the whole is.</dcterms:description>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000369"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010079">
    <rdfs:label xml:lang="en">is encoded by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000339"/>
    <dcterms:description xml:lang="en">A relation between two objects, in which the first object is produced from the information contained in the second object.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000226">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000236"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is function of is a relation between a function and an entity that it is a property of.</dcterms:description>
    <rdfs:label xml:lang="en">is function of</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000291">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000292"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000230"/>
    <dcterms:description xml:lang="en">has target is a relation between a process and an entity, where the entity is present at the beginning  of the process and undergoes a change or transformation in the process.</dcterms:description>
    <rdfs:label xml:lang="en">has target</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000233">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000234"/>
    <dcterms:description xml:lang="en">is implementation of is a relation between an information entity and a specification that it conforms to.</dcterms:description>
    <rdfs:label xml:lang="en">is implementation of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000427">
    <dcterms:description xml:lang="en">A is narrower than B iff the meaning of term A is narrower in scope than the meaning of term B</dcterms:description>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#broader</ns3:equivalentTo>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000477"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is narrower than</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000424"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000482">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000283"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">A is match to B iff A and B are terms with similar (related, broad, close, exact) meanings</dcterms:description>
    <rdfs:label xml:lang="en">is match to</rdfs:label>
    <ns3:equivalentTo>http://www.w3.org/2004/02/skos/core#relatedMatch</ns3:equivalentTo>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000001">
    <ns2:comment>'is related to' is the top level relation in SIO</ns2:comment>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>relations+</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is related to</rdfs:label>
    <dcterms:description xml:lang="en">A is related to B iff there is some relation between A and B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000775">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is refuting evidence for</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000773"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000687">
    <dcterms:description xml:lang="en">exists at is a relation between an entity and a time measurement.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">exists at</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000219">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
    <dcterms:description xml:lang="en">is source of is a relation between a source of information about some entity.</dcterms:description>
    <rdfs:label xml:lang="en">is source of</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000286">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is subsequent version of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000497"/>
    <dcterms:description xml:lang="en">A is subsequent version of B iff A is a variant of B and A derives from B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000671">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_000672"/>
    <rdfs:label xml:lang="en">has identifier</rdfs:label>
    <dcterms:description>a relation between an entity and an identifier.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000243">
    <rdfs:label xml:lang="en">is causally related with</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <dcterms:description xml:lang="en">A transitive, symmetric, temporal relation in which one entity is causally related with another non-identical entity.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000066">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
    <rdfs:label xml:lang="en">has provider</rdfs:label>
    <ns3:equivalentTo>dc:source</ns3:equivalentTo>
    <dcterms:description xml:lang="en">is provided by is a relation between an entity and the entity that provides it.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000497">
    <rdfs:label xml:lang="en">is version of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000272"/>
    <dcterms:description xml:lang="en">is version of is a relation that holds between any two versions in which one is a subsequent or alternate version of (through a branch).</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000278">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is cited by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000252"/>
    <dcterms:description xml:lang="en">is cited by is a relation from an object that is referred to by way of example, authority or proof.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000228">
    <dcterms:description xml:lang="en">has role is a relation between an entity and a role that it bears.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000644"/>
    <rdfs:label xml:lang="en">has role</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000232">
    <skos:example xml:lang="en">glucose-6-phosphate and ADP are outputs in the hexokinase-mediated conversion of glucose to glucose-6-phosphate.</skos:example>
    <rdfs:label xml:lang="en">is output of</rdfs:label>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">is output of is a relation between an entity and a process, where the entity is present at the end of the process.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-relations.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
alison callahan
