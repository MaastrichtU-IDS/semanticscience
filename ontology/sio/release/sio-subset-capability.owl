<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://purl.org/spar/cito/"
   xmlns:ns2="http://schema.org/"
   xmlns:ns3="http://semanticscience.org/resource/"
   xmlns:ns4="http://protege.stanford.edu/plugins/owl/protege#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000695">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000696"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">to be recorded is the capability of an object to be observed in such a way that information about it can be transcribed in a specified format on some physical medium.</dcterms:description>
    <rdfs:label xml:lang="en">to be recorded</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000895">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000894"/>
    <rdfs:label xml:lang="en">to fluoresce</rdfs:label>
    <dcterms:description xml:lang="en">to fluoresce is to emit light as a result of absorbing light or other electromagnetic radiation.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010369">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010364"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">to be electronically modified is the capability of a chemical entity to have electrons added or removed.</dcterms:description>
    <rdfs:label xml:lang="en">to be electronically modified</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000389">
    <dcterms:description xml:lang="en">to extract is the capability to remove certain entities based on selected attribute(s) while allowing other entities to remain.</dcterms:description>
    <rdfs:label xml:lang="en">to extract</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000349"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010347">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000343"/>
    <rdfs:label xml:lang="en">to modify conformation of</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">to modify conformation of is to affect the spatial arrangement of an entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001103">
    <dcterms:description xml:lang="en">to gain a covalent bond is the capability of a chemical entity to have bonds added.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010366"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">to gain a covalent bond</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010353">
    <dcterms:description xml:lang="en">to breathe is the capability to inhale and exhale air into the body during respiration.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000112"/>
    <rdfs:label xml:lang="en">to breathe</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000778">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">to distort</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000378"/>
    <dcterms:description xml:lang="en">to distort is the capability to change the appearance of an entity by some transformation.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001219">
    <rdfs:label xml:lang="en">to test a hypothesis</rdfs:label>
    <dcterms:description xml:lang="en">to test a hypothesis is the capability to evaluate the truth value of a proposition based on gathered evidence.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000724"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000550">
    <dcterms:description xml:lang="en">to increase the activation energy is to require a larger amount of energy in order to form or break a chemical bond.</dcterms:description>
    <rdfs:label xml:lang="en">to increase the activation energy</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:alternative>to inhibit</dcterms:alternative>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000551"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000696">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000694"/>
    <rdfs:label xml:lang="en">to be observed</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">to be observed is the capability of an object to be perceived.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000395">
    <dcterms:alternative xml:lang="en">to modulate</dcterms:alternative>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">to regulate is to control or maintain the rate or speed of an object or process.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000343"/>
    <rdfs:label xml:lang="en">to regulate</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000373">
    <dcterms:description xml:lang="en">to boil is the capability to increase the internal kinetic energy of a material such that it changes state from a solid or liquid to a gas.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000346"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">to boil</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000694">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000702"/>
    <rdfs:label xml:lang="en">to be passively interacted with</rdfs:label>
    <dcterms:description xml:lang="en">to be passively interacted with is the capability of an object to be observed.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-capability.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
