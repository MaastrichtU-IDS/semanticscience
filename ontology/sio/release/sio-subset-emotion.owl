<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://purl.org/spar/cito/"
   xmlns:ns2="http://schema.org/"
   xmlns:ns3="http://semanticscience.org/resource/"
   xmlns:ns4="http://protege.stanford.edu/plugins/owl/protege#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000846">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">hysteria</rdfs:label>
    <dcterms:description xml:lang="en">Hysteria is an unmanageable emotion.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000833">
    <dcterms:description xml:lang="en">Embarrassment is the emotion of intense discomfort with oneself, experienced upon having a socially unacceptable act or condition witnessed by or revealed to other.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:label xml:lang="en">embarassment</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000842">
    <rdfs:label xml:lang="en">grief</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">grief is an emotion in response to loss, whether physical or abstract including death, unemployment, ill health or the end of a relationship.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000863"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000863">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:alternative>sad</dcterms:alternative>
    <dcterms:alternative>unhappiness</dcterms:alternative>
    <dcterms:alternative>unhappy</dcterms:alternative>
    <dcterms:description xml:lang="en">sadness is emotional pain associated with, or characterized by feelings of disadvantage, loss, despair, helplessness, sorrow, and rage.</dcterms:description>
    <rdfs:label xml:lang="en">sadness</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000839">
    <dcterms:alternative>appreciation</dcterms:alternative>
    <dcterms:alternative>thankfullness</dcterms:alternative>
    <dcterms:alternative>gratification</dcterms:alternative>
    <dcterms:alternative>gratefulness</dcterms:alternative>
    <dcterms:description xml:lang="en">Gratitude, thankfulness, gratefulness, or appreciation is a feeling, emotion or attitude in acknowledgment of a benefit that one has received or will receive.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">gratitude</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001281">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description>Humiliation is the abasement of pride, which creates mortification or leads to a state of being humbled or reduced to lowliness or submission.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000845"/>
    <rdfs:label xml:lang="en">humiliation</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000866">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">shock is an emotion of sudden upset or surprise.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:label xml:lang="en">shock</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000850">
    <rdfs:label xml:lang="en">joy</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000840"/>
    <dcterms:description xml:lang="en">joy is an emotion of intense happiness.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000950">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <rdfs:label xml:lang="en">resentment</rdfs:label>
    <dcterms:description xml:lang="en">resentment is disgust directed toward a higher status individual.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001284">
    <dcterms:alternative>contentment</dcterms:alternative>
    <dcterms:alternative>pleasure</dcterms:alternative>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">satisfaction</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <dcterms:description>satisfaction is the emotion of fulfillling one's wishes, expectations, or needs.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000358">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">intent</rdfs:label>
    <dcterms:description xml:lang="en">intent is a desire to realize a particular outcome.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000825"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000851">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <dcterms:description xml:lang="en">loathing is an intense dislike or disgust.</dcterms:description>
    <rdfs:label xml:lang="en">loathing</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000848">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdfs:label xml:lang="en">interest</rdfs:label>
    <dcterms:description xml:lang="en">interest is the emotion of wanting to know or learn about something or someone.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000816">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">apathy is an emotion characterized by lack of interest, enthusiasm, or concern.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000847"/>
    <rdfs:label xml:lang="en">apathy</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000871">
    <dcterms:description xml:lang="en">terror is the extreme feeling of fear.</dcterms:description>
    <rdfs:label xml:lang="en">terror</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000829"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000812">
    <dcterms:description xml:lang="en">affection is an emotion characterized with a feeling or type of love for another living thing.</dcterms:description>
    <rdfs:label xml:lang="en">affection</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
alison callahan
leonid chepelev
kevin cohen
melanie courtot
geraint duck
laura furlong
elisa kendall
tatsuya kushida
luke mccarthy
jim mccusker
jose miguel cruz-toledo
chris mungall
robert hoehndorf
simon jupp
jin-dong kim
dana klassen
thomas luetteke
james malone
chris mungall
david osumi-sutherland
tazro ohta
nuria queralt
stephen reed
alexandre riazanov
matthias samwald
robert stevens
mark wilkinson
karin verspoor
natalia villanueva-rosales</dc:contributor>
    <dc:creator xml:lang="en">Michel Dumontier</dc:creator>
    <dcterms:creator rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://orcid.org/0000-0003-4727-9435</dcterms:creator>
    <dcterms:description xml:lang="en">The semanticscience integrated ontology (SIO) provides a simple, integrated ontology (types, relations) for objects, processes and their attributes.

This project provides foundational support for the Bio2RDF (http://bio2rdf.org) and SADI (http://sadiframework.org) projects. 

website: http://semanticscience.org
email: sio-ontology@googlegroups.com
mailing list: http://groups.google.com/group/sio-ontology
</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2010-03-29</dcterms:issued>
    <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:rights>free to use,share,modify. modify with attribution [http://creativecommons.org/licenses/by/4.0/].</dcterms:rights>
    <dcterms:title xml:lang="en">Semanticscience Integrated Ontology (SIO)</dcterms:title>
    <ns1:citesAsAuthority rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.jbiomedsem.com/content/5/1/14</ns1:citesAsAuthority>
    <vann:preferredNamespacePrefix xml:lang="en">sio</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>http://semanticscience.org/resource/</vann:preferredNamespaceUri>
    <ns2:comment>general class inclusion axioms:
'is part of' some 'physical entity' subClassOf 'is located in' some 'physical entity'

role chains:
'has capability' o 'is realized in' -&gt; 'is participant in'</ns2:comment>
    <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://sio.semanticscience.org</rdfs:seeAlso>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-01</dcterms:modified>
    <dc:identifier>sio.owl</dc:identifier>
    <owl:versionInfo>sio-subset-emotion.owl</owl:versionInfo>
    <owl:versionIRI rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001195">
    <rdfs:label xml:lang="en">behaviour</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
    <ns3:subset>behaviour+</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Behaviour is the set of actions and mannerisms made by systems (biological or otherwise) in response to stimuli or inputs, whether internal or external, conscious or subconscious, overt or covert, and voluntary or involuntary.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000868">
    <dcterms:description xml:lang="en">sorrow is the emotion that is characterized by a long term state of intense sadness, distress and a degree of resignation (not accepting).</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000863"/>
    <rdfs:label xml:lang="en">sorrow</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000858">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000840"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pleasure</rdfs:label>
    <dcterms:description xml:lang="en">pleasure is an emotion of happy satisfaction and enjoyment.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000865">
    <rdfs:label xml:lang="en">shame</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:description xml:lang="en">shame is the emotion borne from feeling responsible for the commission of an offense.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000830">
    <rdfs:label xml:lang="en">ecstasy</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <dcterms:description xml:lang="en">ecstacy is an emotion characterized by a heightened state of consciousness with total involvement of a subject.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000410">
    <dcterms:description xml:lang="en">anger is disgust directed toward an equal status individual.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <rdfs:label xml:lang="en">anger</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000859">
    <dcterms:description xml:lang="en">pride is an emotion of satisfaction of attachment toward one's own or another's choices and actions, or toward a whole group of people, and is a product of praise, independent self-reflection, or a fulfilled feeling of belonging.</dcterms:description>
    <rdfs:label xml:lang="en">pride</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000864"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000829">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000837"/>
    <rdfs:label xml:lang="en">dread</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">dread is the instense negative emotion that induces fear and apprehension.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000853">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000825"/>
    <rdfs:label xml:lang="en">lust</rdfs:label>
    <dcterms:description xml:lang="en">lust is the strong desire for sex.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000819">
    <rdfs:label xml:lang="en">boldness</rdfs:label>
    <dcterms:description xml:lang="en">boldness is the trait of being willing to undertake things that involve risk or danger.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000814">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">annoyance</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:description xml:lang="en">Annoyance is an unpleasant emtion that is characterized by a abnormal or excessive sensitivity to some external stimulus.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000006">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>process+</ns3:subset>
    <rdfs:label xml:lang="en">process</rdfs:label>
    <dcterms:description xml:lang="en">A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000831">
    <dcterms:description xml:lang="en">A positive emotion is an emotion that feels good.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000276"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">positive emotion</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001283">
    <rdfs:label xml:lang="en">discouragement</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:alternative>discouraged</dcterms:alternative>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description>Discouragement is the emtion of having lost confidence or enthusiasm.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000856">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000825"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">passion</rdfs:label>
    <dcterms:description xml:lang="en">passion is the intense desire for something.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000857">
    <dcterms:description xml:lang="en">Pity is the emotion of sadness or sorrow for another.</dcterms:description>
    <rdfs:label xml:lang="en">pity</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000824">
    <rdfs:label xml:lang="en">depression</rdfs:label>
    <dcterms:description xml:lang="en">depression is an unpleasant emotion linked to aversion to activity that can affect a person's thoughts, behavior, feelings and physical well-being. Depressed individuals may feel sad, anxious, empty, hopeless, worried, helpless, worthless, guilty, irritable, or restless.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000863"/>
    <dcterms:alternative>depressed</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000860">
    <dcterms:description xml:lang="en">Rage is a feeling of intense anger that is associated with the Fight-or-flight response.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000410"/>
    <rdfs:label xml:lang="en">rage</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000828">
    <dcterms:description xml:lang="en">Disgust is a feeling of revulsion or profound disapproval aroused by something unpleasant or offensive.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">disgust</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000844"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000867">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:label xml:lang="en">shyness</rdfs:label>
    <dcterms:description xml:lang="en">shyness is an emotion of apprehension, lack of comfort, or awkwardness experienced when in proximity to, approaching, or being approached by other individuals, especially in new situations or with unfamiliar individuals.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000813">
    <rdfs:label xml:lang="en">angst</rdfs:label>
    <dcterms:description xml:lang="en">angst is the intense feeling of apprehension, anxiety or inner turmoil.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000815"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000845">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:description xml:lang="en">hurt is an unpleasant feeling, emotion or sensation.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">hurt</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000825">
    <rdfs:label xml:lang="en">desire</rdfs:label>
    <dcterms:description xml:lang="en">desire is a strong emotion of wanting to have something or wishing for something to happen.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000848"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000836">
    <dcterms:description xml:lang="en">excitement is a positive emotion of feeling great enthusiasm and eagerness.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdfs:label xml:lang="en">excitement</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000870">
    <dcterms:description xml:lang="en">surprise is a brief emotion experienced as the result of an unexpected event. </dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdfs:label xml:lang="en">surprise</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000838">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000814"/>
    <dcterms:description xml:lang="en">Frustration is an emotion that arises from the perceived resistance to the fulfillment of individual will. </dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">frustration</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000826">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000863"/>
    <rdfs:label xml:lang="en">despair</rdfs:label>
    <dcterms:description xml:lang="en">despair is depression, hopelessness or lack of hope.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001286">
    <rdfs:label xml:lang="en">irritability</rdfs:label>
    <dcterms:description>irritability is the negative emotion of quick excitability to annoyance, impatience, or anger.</dcterms:description>
    <dcterms:alternative>irritable</dcterms:alternative>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000832">
    <rdfs:label xml:lang="en">negative emotion</rdfs:label>
    <dcterms:description xml:lang="en">negative emotion is an emotion that does not feel good.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000276"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000949">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">apprehension is the negative emotion that something unpleasant will occur.</dcterms:description>
    <rdfs:label xml:lang="en">apprehension</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000843">
    <rdfs:label xml:lang="en">hope</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">hope is an emotion of belief in a positive outcome related to events and circumstances in one's life.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000837">
    <rdfs:label xml:lang="en">fear</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000949"/>
    <dcterms:description xml:lang="en">Fear is a negative emotion induced by a perceived threat that induces one to hide or move quickly away from the location of the perceived threat.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000847">
    <rdfs:label xml:lang="en">indifference</rdfs:label>
    <dcterms:description xml:lang="en">indifference is an emotion characterized by lack of interest, concern, or sympathy.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000276"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000852">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Loneliness is an unpleasant emotion in which a person feels a strong sense of emptiness, yearning distress and solitude resulting from inadequate quantity or quality of social relationships.</dcterms:description>
    <rdfs:label xml:lang="en">loneliness</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000834">
    <rdfs:label xml:lang="en">envy</rdfs:label>
    <dcterms:description xml:lang="en">envy is an emotion that occurs when a person lacks another's (perceived) superior quality, achievement or possession and wishes that the other lacked it.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000000">
    <dcterms:description xml:lang="en">Every thing is an entity.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">entity</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000827">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:description xml:lang="en">disappointment is the feeling of dissatisfaction that follows the failure of expectations or hopes to manifest.</dcterms:description>
    <dcterms:alternative>disappointed</dcterms:alternative>
    <dcterms:alternative>disappointing</dcterms:alternative>
    <rdfs:label xml:lang="en">disappointment</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001285">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description>suicidal is the emotion of being deeply unhappy or depressed with thoughts of killing one's self.</dcterms:description>
    <rdfs:label xml:lang="en">suicidal</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000862">
    <dcterms:description xml:lang="en">remorse is an emotion of personal regret felt by a person after he or she has committed an act which they deem to be shameful, hurtful, or violent.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">remorse</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000861"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000817">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">arousal is an emotion characterized by state of reactive to stimuli. It involves the activation of the reticular activating system in the brain stem, the autonomic nervous system and the endocrine system, leading to increased heart rate and blood pressure and a condition of sensory alertness, mobility and readiness to respond.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdfs:label xml:lang="en">arousal</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000823">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000825"/>
    <dcterms:description xml:lang="en">curiosity is the strong desire to know or learn something.</dcterms:description>
    <rdfs:label xml:lang="en">curiosity</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000276">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001195"/>
    <dcterms:description xml:lang="en">An emotion is a process (experience) that arises internally or from an involuntary physiological response to a stimulus.</dcterms:description>
    <rdfs:label xml:lang="en">emotion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <ns3:subset>emotion++</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000872">
    <rdfs:label xml:lang="en">wonder</rdfs:label>
    <dcterms:description xml:lang="en">wonder is an emotion of perceiving something very rare or unexpected, but not threatening.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000870"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000818">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <dcterms:description xml:lang="en">awe is an emotion produced by that which is grand, sublime or powerful and is characterized by a combination of joy, fear and admiration/reverence/respect. </dcterms:description>
    <rdfs:label xml:lang="en">awe</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001287">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <dcterms:description>indecision is the emotion of being unable to choose between two or more possible courses of action.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">indecision</rdfs:label>
    <dcterms:alternative>indecisiveness</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000840">
    <dcterms:description xml:lang="en">happiness is an emotion characterized by positive or pleasant emotions ranging from contentment to intense joy.</dcterms:description>
    <rdfs:label xml:lang="en">happiness</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000864">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">satisfaction is an emotion of fulfillment of one's wishes, expectations, or needs, or the pleasure derived from this.</dcterms:description>
    <rdfs:label xml:lang="en">satisfaction</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000822"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001282">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description>hunger is the craving for food.</dcterms:description>
    <rdfs:label xml:lang="en">hunger</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000815">
    <dcterms:description xml:lang="en">anxiety is an emotion charactersized by intense feeling of fear and concern coupled with a physical response.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">anxiety</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000949"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000951">
    <rdfs:label xml:lang="en">pain</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Pain is an unpleasant sensory and emotional experience associated with actual or potential tissue damage, or described in terms of such damage.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000845"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000849">
    <dcterms:description xml:lang="en">jealousy is an emotion and typically refers to the negative thoughts and feelings of insecurity, fear, and anxiety over an anticipated loss of something that the person values, particularly in reference to a human connection.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000834"/>
    <rdfs:label xml:lang="en">jealousy</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000844">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Hostility is the intense negative emotion of being in conflict or opposition to someone or something.</dcterms:description>
    <rdfs:label xml:lang="en">hostility</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000822">
    <rdfs:label xml:lang="en">contentment</rdfs:label>
    <dcterms:description xml:lang="en">contentment is an emotion characterized by acknowledgement and satisfaction of the current state of affairs.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000840"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000861">
    <rdfs:label xml:lang="en">regret</rdfs:label>
    <dcterms:description xml:lang="en">regret is a feeling of sadness, repentance, or disappointment over something that has happened or been done.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000873"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000854">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000863"/>
    <dcterms:description xml:lang="en">misery is a feeling of great unhappiness, suffering and/or pain.</dcterms:description>
    <rdfs:label xml:lang="en">misery</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000855">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000837"/>
    <rdfs:label xml:lang="en">panic</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Panic is a sudden emotion of fear which is so strong as to dominate or prevent reason and logical thinking, replacing it with overwhelming feelings of anxiety and frantic agitation consistent with an animalistic fight-or-flight reaction.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000873">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000949"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">worry is the emotion characterized by concer over a real or imaginary issue.</dcterms:description>
    <rdfs:label xml:lang="en">worry</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000869">
    <rdfs:label xml:lang="en">suffering</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000845"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Suffering is the unpleasant emotion and aversion associated with the perception of harm or threat of harm in an individual.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000841">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:label xml:lang="en">guilt</rdfs:label>
    <dcterms:alternative>guilty</dcterms:alternative>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Guilt is the emotion borne from feeling responsible for the commission of an offense and arises out of public humiliation.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000411">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <rdfs:label xml:lang="en">hate</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">Hate is a deep and emotional extreme dislike, directed against a certain object or class of objects. </dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000820">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">boredom</rdfs:label>
    <dcterms:description xml:lang="en">boredom is the emotion experience by those not interested in their surroundings or available activities.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000832"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000835">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000840"/>
    <dcterms:description xml:lang="en">euphoria is an emotion characterized by intense feelings of well-being, elation, happiness, ecstasy, excitement, and joy.</dcterms:description>
    <rdfs:label xml:lang="en">euphoria</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000821">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000828"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">contempt</rdfs:label>
    <dcterms:description xml:lang="en">contempt is disgust towards a lower status individual.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000412">
    <dcterms:description xml:lang="en">love is an emotion of a strong affection and personal attachment.</dcterms:description>
    <rdfs:label xml:lang="en">love</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000831"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-emotion.owl"/>
  </rdf:Description>
</rdf:RDF>
