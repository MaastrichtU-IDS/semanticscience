  <rdf:Description rdf:about="http://semanticscience.org/resource/isProductOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example xml:lang="en">glucose-6-phosphate is the product of the hexokinase-mediated conversion of glucose to glucose-6-phosphate.</skos:example>
    <dcterms:description xml:lang="en">is product of is a relation between an entity and a process, where the entity is present at the end  of the process as a result of a transformation in the process target.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/isOutputOf"/>
    <dc:identifier>SIO_000311</dc:identifier>
