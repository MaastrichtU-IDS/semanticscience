    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dc:identifier>SIO_010790</dc:identifier>
    <dcterms:description xml:lang="en">aggregate of carbon nanorods is an allotrope of carbon considered to be the least compressible material known, as measured by its isothermal bulk modulus; aggregated diamond nanorods have a modulus of 491 gigapascals (GPa), while a conventional diamond has a modulus of 442 GPa. ADNRs are also 0.3% denser than regular diamond.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CarbonAllotrope"/>
