  <rdf:Description rdf:about="http://semanticscience.org/resource/isSpecializationOf">
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/isGeneralizationOf"/>
    <skos:example xml:lang="en">a weather forecast for the city of London produced at a specific time is a specialization of a weather forecast for the city of London.</skos:example>
    <dcterms:description xml:lang="en">is specialization of is a relation between a more specific instance (in terms of spatial/temporal localization &amp; other attributres) than the other.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/isVariantOf"/>
    <ns1:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.w3.org/ns/prov#specializationOf</ns1:equivalentTo>
    <dc:identifier>SIO_001096</dc:identifier>
    <rdfs:label xml:lang="en">is specialization of</rdfs:label>
