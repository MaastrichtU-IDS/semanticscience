    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">differential diagnosis</rdfs:label>
    <dc:identifier>SIO_001002</dc:identifier>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/MedicalProcedure"/>
    <dcterms:description xml:lang="en">A differential diagnosis (sometimes abbreviated DDx, ddx, DD, D/Dx, or ΔΔ) is a systematic diagnostic method used to identify the presence of an entity where multiple alternatives are possible (and the process may be termed differential diagnostic procedure), and may also refer to any of the included candidate alternatives (which may also be termed candidate condition).</dcterms:description>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/SIO_001002"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/DifferentialDiagnosis"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/differential-diagnosis"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-camelcase-label.owl"/>
  </rdf:Description>
