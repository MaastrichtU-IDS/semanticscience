  <rdf:Description rdf:about="http://semanticscience.org/resource/Longitude">
    <dcterms:description xml:lang="en">Longitude is a geographic position that refers to  the angle east or west of a reference meridian between the two geographical poles to another meridian that passes through an arbitrary point.</dcterms:description>
