  <rdf:Description rdf:about="http://semanticscience.org/resource/positivelyRegulates">
    <dc:identifier>SIO_001401</dc:identifier>
    <rdfs:label xml:lang="en">positively regulates</rdfs:label>
    <dc:description xml:lang="en">x positively regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an effect that increases the frequency, rate or extent of y</dc:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
