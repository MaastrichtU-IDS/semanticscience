    <rdfs:range rdf:resource="http://semanticscience.org/resource/RealizableEntity"/>
    <dcterms:description xml:lang="en">is base for is a relation between a quality and the realizable entity that it is the basis for.</dcterms:description>
    <rdfs:label xml:lang="en">is base for</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/isAttributeOf"/>
    <skos:example xml:lang="en">the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization).</skos:example>
