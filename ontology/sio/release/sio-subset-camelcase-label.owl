  <rdf:Description rdf:about="http://semanticscience.org/resource/X-axis">
    <dcterms:description xml:lang="en">An x-axis is a Cartesian coordinate axis that is aligned with the horizon.</dcterms:description>
    <dc:identifier>SIO_000452</dc:identifier>
    <dcterms:alternative>horizontal axis</dcterms:alternative>
    <rdfs:label xml:lang="en">x-axis</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <ns3:comment xml:lang="en">In most figures, this axis represents categories, such as months, market segments, or other non-numeric data.</ns3:comment>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CartesianCoordinateAxis"/>
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/Y-axis"/>
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/Z-axis"/>
    <skos:example xml:lang="en">The horizontal axis in http://tinyurl.com/opwnvm</skos:example>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/x-axis"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/SIO_000452"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/X-axis"/>
