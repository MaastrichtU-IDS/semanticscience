    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-camelcase-label.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/Diamond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CarbonAllotrope"/>
    <dc:identifier>SIO_010787</dc:identifier>
    <dcterms:description xml:lang="en">diamond is a carbon allotrope in which each carbon atom in diamond is covalently bonded to four other carbons in a tetrahedron. These tetrahedrons together form a 3-dimensional network of puckered six-membered rings of atoms.</dcterms:description>
    <rdfs:label xml:lang="en">diamond</rdfs:label>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/Diamond"/>
