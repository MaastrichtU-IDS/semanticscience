    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/Argument"/>
    <rdfs:subClassOf rdf:nodeID="N15a64017f63148948dddaf11a3435890"/>
    <dcterms:description xml:lang="en">A valid argument is an argument where the truth of the conclusion is a logical consequence of the premises and (consequently) its corresponding conditional is a necessary truth.</dcterms:description>
