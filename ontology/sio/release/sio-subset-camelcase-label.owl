  <rdf:Description rdf:about="http://semanticscience.org/resource/Gesturing">
    <dc:identifier>SIO_001059</dc:identifier>
    <dcterms:description xml:lang="en">gesturing is a form of non-verbal communication in which visible bodily actions communicate particular messages, either in place of speech or together and in parallel with spoken words. Gestures include movement of the hands, face, or other parts of the body.</dcterms:description>
