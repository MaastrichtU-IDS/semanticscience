    <dc:identifier>SIO_000944</dc:identifier>
    <dc:identifier>SIO_001246</dc:identifier>
    <dcterms:description xml:lang="en">an interval is a set of real numbers with the property that any number that lies between two numbers in the set is also included in the set.</dcterms:description>
    <dcterms:description xml:lang="en">An interval is a set of real numbers that includes all numbers between any two numbers in the set.</dcterms:description>
    <rdfs:label xml:lang="en">interval</rdfs:label>
    <skos:example xml:lang="en">The set of all numbers x satisfying 0&lt;=x&lt;=1 is an interval which contains 0 and 1, as well as numbers between them.</skos:example>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/SIO_000944"/>
