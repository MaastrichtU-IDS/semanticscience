  <rdf:Description rdf:about="http://semanticscience.org/resource/Worm">
    <dcterms:description xml:lang="en">A worm is a non-arthropod invertebrate animal that typically have a long cylindrical tube-like body and no legs.</dcterms:description>
    <rdfs:label xml:lang="en">worm</rdfs:label>
    <dc:identifier>SIO_000488</dc:identifier>
