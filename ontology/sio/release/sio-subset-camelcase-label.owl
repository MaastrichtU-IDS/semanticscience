  <rdf:Description rdf:about="http://semanticscience.org/resource/hasBasis">
    <rdfs:range rdf:resource="http://semanticscience.org/resource/Quality"/>
    <rdfs:label xml:lang="en">has basis</rdfs:label>
    <dcterms:description xml:lang="en">has basis is a relation between a realizable entity and the quality that forms the basis for it.</dcterms:description>
    <skos:example xml:lang="en">the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization).</skos:example>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/hasAttribute"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/isBaseFor"/>
    <rdfs:domain rdf:resource="http://semanticscience.org/resource/RealizableEntity"/>
    <dc:identifier>SIO_000641</dc:identifier>
    <owl:equivalentProperty rdf:resource="http://semanticscience.org/resource/SIO_000641"/>
    <owl:equivalentProperty rdf:resource="http://semanticscience.org/resource/has-basis"/>
    <owl:equivalentProperty rdf:resource="http://semanticscience.org/resource/hasBasis"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-camelcase-label.owl"/>
  </rdf:Description>
