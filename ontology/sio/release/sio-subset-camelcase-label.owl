  <rdf:Description rdf:about="http://semanticscience.org/resource/Depression">
    <rdfs:label xml:lang="en">depression</rdfs:label>
    <dcterms:description xml:lang="en">depression is an unpleasant emotion linked to aversion to activity that can affect a person's thoughts, behavior, feelings and physical well-being. Depressed individuals may feel sad, anxious, empty, hopeless, worried, helpless, worthless, guilty, irritable, or restless.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/Sadness"/>
