  <rdf:Description rdf:about="http://semanticscience.org/resource/ValueAxis">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/Axis"/>
    <dcterms:description xml:lang="en">A value axis is an axis in which the position along the line is partioned into numeric values.</dcterms:description>
    <owl:equivalentClass rdf:nodeID="Nce81ca30e5a74651b53001ac68a53d78"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/SIO_000458"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/value-axis"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/ValueAxis"/>
    <ns3:comment xml:lang="en">A value axis holds the properties of having a minimum and a maximum value, and is usually associated with tickmarks that indicate intervals along the axis.</ns3:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
