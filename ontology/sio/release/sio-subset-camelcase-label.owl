  <rdf:Description rdf:about="http://semanticscience.org/resource/AdditionReaction">
    <dcterms:description xml:lang="en">An addition reaction is an organic reaction where two or more molecules combine to form a larger one. Addition reactions are limited to chemical compounds that have multiply-bonded atoms:
    * Molecules with carbon-carbon double bonds or triple bonds
    * Molecules with carbon - hetero double bonds like C=O or C=N</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/OrganicReaction"/>
    <dc:identifier>SIO_010518</dc:identifier>
