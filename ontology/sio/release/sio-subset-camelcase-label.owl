  <rdf:Description rdf:about="http://semanticscience.org/resource/RadioReceiver">
    <dc:identifier>SIO_000926</dc:identifier>
    <rdfs:label xml:lang="en">radio receiver</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CommunicationDevice"/>
    <dcterms:description xml:lang="en">A radio receiver is a communication device that receives its input from an antenna, uses electronic filters to separate a wanted radio signal from all other signals picked up by this antenna, amplifies it to a level suitable for further processing, and finally converts through demodulation and decoding the signal into a form usable for the consumer, such as sound, pictures, digital data, measurement values, navigational positions.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
