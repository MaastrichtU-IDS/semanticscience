  <rdf:Description rdf:about="http://semanticscience.org/resource/PlateauLine">
    <dcterms:description xml:lang="en">An plateau line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is zero.</dcterms:description>
