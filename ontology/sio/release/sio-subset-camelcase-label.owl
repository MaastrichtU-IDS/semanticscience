  <rdf:Description rdf:about="http://semanticscience.org/resource/ElectronicStructure">
    <dcterms:description xml:lang="en">electronic structure is the electron configuration is the distribution of electrons of an atom or molecule (or other physical structure) in atomic or molecular orbitals.</dcterms:description>
    <dcterms:alternative>electronic configuration</dcterms:alternative>
    <dc:identifier>SIO_001099</dc:identifier>
