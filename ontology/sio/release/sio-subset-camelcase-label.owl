  <rdf:Description rdf:about="http://semanticscience.org/resource/hasProperPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    <rdfs:label xml:lang="en">has proper part</rdfs:label>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/isProperPartOf"/>
    <dcterms:description xml:lang="en">has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part.</dcterms:description>
    <skos:example xml:lang="en">a car has an engine as a proper part; a car has a piston as a proper part;</skos:example>
