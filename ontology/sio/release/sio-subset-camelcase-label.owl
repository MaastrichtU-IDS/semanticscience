  <rdf:Description rdf:about="http://semanticscience.org/resource/Sequence">
    <dcterms:alternative>ordered list</dcterms:alternative>
    <dcterms:description xml:lang="en">A sequence is an ordered list of entities. Like a set, it contains members (also called elements, or terms).</dcterms:description>
    <dc:identifier>SIO_001118</dc:identifier>
    <rdfs:subClassOf rdf:nodeID="Nba585a878a504e23b9899305b3a3edfc"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/List"/>
    <skos:example xml:lang="en">For example, (M, A, R, Y) is a sequence of letters that differs from (A, R, M, Y), as the ordering matters, and (1, 1, 2, 3, 5, 8), which contains the number 1 at two different positions, is a valid sequence. </skos:example>
    <rdfs:label xml:lang="en">sequence</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/SIO_001118"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/Sequence"/>
    <owl:equivalentClass rdf:resource="http://semanticscience.org/resource/sequence"/>
