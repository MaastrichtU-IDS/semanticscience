  <rdf:Description rdf:about="http://semanticscience.org/resource/CartesianCoordinateSystem">
    <dc:identifier>SIO_000321</dc:identifier>
    <dcterms:description xml:lang="en">A Cartesian coordinate system specifies each point uniquely in a plane by a pair of numerical coordinates, which are the signed distances from the point to two fixed perpendicular directed lines, measured in the same unit of length.</dcterms:description>
