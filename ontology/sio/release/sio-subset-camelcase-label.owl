    <rdfs:label xml:lang="en">stationary point</rdfs:label>
    <dcterms:description xml:lang="en">A stationary point is a point that is part of a curve in which the derivative at that point is zero, and hence its value is at least a local maximum or minimum.</dcterms:description>
