    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001050"/>
    <dcterms:description xml:lang="en">A specimen is a portion of material for use in testing, examination, or study.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
