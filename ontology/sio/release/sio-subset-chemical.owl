  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000790">
    <dcterms:description xml:lang="en">A non-protein coding RNA (ncRNA) gene is a gene that encodes for a RNA transcript that is not further translated into a protein product.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010035"/>
