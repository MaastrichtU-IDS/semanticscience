  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010447">
    <dcterms:description xml:lang="en">A start codon is the first codon of a messenger RNA (mRNA) transcript translated by a ribosome. The start codon is almost always preceded by an untranslated region 5' UTR.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010095"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
