    <skos:exactMatch>CHEMINF:440533</skos:exactMatch>
    <dcterms:alternative xml:lang="en">mixture</dcterms:alternative>
    <rdfs:label xml:lang="en">chemical substance</rdfs:label>
    <dcterms:description xml:lang="en">A chemical substance is a chemical entity composed of two or more weakly (non-covalently) interacting chemical entities.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000092">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010346"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
