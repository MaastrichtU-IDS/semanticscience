  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010439">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010437"/>
    <rdfs:label xml:lang="en">messenger</rdfs:label>
    <dcterms:description xml:lang="en">A mesenger is a molecule involved in either signal detection or signal propagation from receptors on the cell surface to target molecules inside the cell, in the cytoplasm or nucleus.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
