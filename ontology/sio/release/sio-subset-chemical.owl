    <rdfs:label xml:lang="en">gene enhancer</rdfs:label>
    <dcterms:description xml:lang="en">A gene enhancer is a short region of DNA that can be bound with proteins to enhance transcription levels of genes in a gene cluster.</dcterms:description>
