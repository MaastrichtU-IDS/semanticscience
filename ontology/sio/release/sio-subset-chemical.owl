    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">van der Waals' interaction is an a weak submolecular interaction between an instantaneous dipole and induced dipole.</dcterms:description>
