  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001233">
    <rdfs:label xml:lang="en">small nuclear RNA (snRNA)</rdfs:label>
    <dcterms:description xml:lang="en">A small nuclear RNA (snRNA) is a small RNA molecule that is located in the nucleus of a cell.</dcterms:description>
