    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010433">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010033"/>
    <dcterms:description xml:lang="en">A low barrier hydrogen bond is a shorter, stronger hydrogen bond that is formed between both heteroatoms.</dcterms:description>
    <rdfs:label xml:lang="en">low barrier hydrogen bond</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
