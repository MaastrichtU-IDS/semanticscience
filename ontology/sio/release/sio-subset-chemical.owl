    <rdfs:label xml:lang="en">beryllium atom</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch>CHEBI:30501</skos:exactMatch>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
