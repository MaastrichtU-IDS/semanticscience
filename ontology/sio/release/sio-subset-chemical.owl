    <rdfs:label xml:lang="en">transfer RNA (tRNA)</rdfs:label>
    <dcterms:description xml:lang="en">A transfer RNA (tRNA) is an RNA molecule that aids in the translation of a messenger RNA (mRNA) to produce a protein product.</dcterms:description>
    <dcterms:alternative xml:lang="en">tRNA</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
