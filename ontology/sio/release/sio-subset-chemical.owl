  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010038">
    <rdfs:label xml:lang="en">drug</rdfs:label>
    <dcterms:description xml:lang="en">A drug is a chemical substance that contains one or more active ingredients that regulate one or more biological processes.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011126"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
