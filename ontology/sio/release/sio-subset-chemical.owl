    <dcterms:description xml:lang="en">A solid-state drive (SSD) is a data storage device that uses solid-state memory to store persistent data.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000598"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
