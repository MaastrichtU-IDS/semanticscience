    <skos:exactMatch>CHEBI:33387</skos:exactMatch>
    <rdfs:label xml:lang="en">neptunium atom</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010097">
    <dcterms:description xml:lang="en">Precursor mRNA (pre-mRNA) is a single strand of messenger ribonucleic acid (mRNA) that is synthesized from a DNA template throught transcription.</dcterms:description>
    <rdfs:label xml:lang="en">pre-mRNA</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010099"/>
