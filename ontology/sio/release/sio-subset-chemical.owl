  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010468">
    <dcterms:description xml:lang="en">An alpha helix is structural region of a protein that is characterized by 3.6 residues per turn,  a translation of 1.5 angstroms along the helical axis in which backbone N-H groups form a hydrogen bond to the backbone carboxyl group of the amino acid four residues prior.</dcterms:description>
    <rdfs:label xml:lang="en">alpha helix</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010471"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010418">
    <rdfs:label xml:lang="en">solute</rdfs:label>
    <dcterms:description xml:lang="en">A solute is a substance that becomes dissolved in a solvent.</dcterms:description>
