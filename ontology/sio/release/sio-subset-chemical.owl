  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001224">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010072"/>
    <rdfs:label xml:lang="en">amino acid</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An amino acid is an organic molecule composed of a carbon bonded to four different groups: a carboxyl group, an amino group, an R group, and a hydrogen atom. In the case of glycine, the R group is another hydrogen atom.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010096">
    <dcterms:description xml:lang="en">A mature RNA is a ribonucleic acid that contains an untranslated region (UTR) and protein coding sequence and lacks introns.</dcterms:description>
    <rdfs:label xml:lang="en">mature mRNA</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010099"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
