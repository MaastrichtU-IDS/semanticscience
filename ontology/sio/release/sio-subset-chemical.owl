  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010445">
    <rdfs:label xml:lang="en">exon</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An exon is a nucleotide sequence encoded by a gene that remains present within the final mature RNA product of that gene after introns have been removed by RNA splicing. </dcterms:description>
