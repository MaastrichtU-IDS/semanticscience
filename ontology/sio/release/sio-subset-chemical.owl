  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010498">
    <rdfs:label xml:lang="en">single bond</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011118"/>
    <dcterms:description xml:lang="en">A single bond is a covalent bond between a pair of atoms in which one pair of electrons are shared.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010451">
    <rdfs:label xml:lang="en">splice site</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010095"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A splice site is a region required for the excision of an intron and connection to another exon.</dcterms:description>
