  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010432">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011125"/>
    <dcterms:description xml:lang="en">A ligand is a molecule that is part of a complex by weakly interacting with another molecule.</dcterms:description>
    <rdfs:label xml:lang="en">ligand</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
