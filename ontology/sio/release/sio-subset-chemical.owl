  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001428">
    <dcterms:description xml:lang="en">an ingredient is a chemical substance that forms part of a mixture.</dcterms:description>
    <rdfs:label xml:lang="en">ingredient</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011126"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
