>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010450">
    <dcterms:description xml:lang="en">An RNA transcript is an RNA molecule that is produced from transcription of a nucleic acid template.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010009"/>
    <rdfs:label xml:lang="en">RNA transcript</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010775">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010455"/>
    <rdfs:label xml:lang="en">stereoisomer</rdfs:label>
    <dcterms:description xml:lang="en">A stereoisomer is an isomer in which the atomic connectivity is the same, but differs in its spatial arrangement of atoms.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011026">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">cobalt atom</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <skos:exactMatch>CHEBI:27638</skos:exactMatch>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010084">
    <dcterms:description xml:lang="en">An operon is a collection of contiguous genes transcribed as a single (polycistronic) mRNA.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010335"/>
    <ns1:similarTo>SO:0000178</ns1:similarTo>
    <rdfs:label xml:lang="en">operon</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010416">
    <dcterms:description xml:lang="en">A buffer is a dissolved chemical substance that resists change in pH upon addition of small amounts of acid or base.</dcterms:description>
    <rdfs:label xml:lang="en">buffer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010427"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010506">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">molecular complex</rdfs:label>
    <dcterms:description xml:lang="en">A molecular complex is a chemical complex composed of at least one weakly interacting molecule.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010342"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010095">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An RNA transcript component is a region of an RNA transcript. </dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010335"/>
    <rdfs:label xml:lang="en">RNA transcript component</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011010">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">sodium atom</rdfs:label>
    <skos:exactMatch>CHEBI:26708</skos:exactMatch>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011024">
    <rdfs:label xml:lang="en">manganese atom</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <skos:exactMatch>CHEBI:18291</skos:exactMatch>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011104">
    <rdfs:label xml:lang="en">thorium atom</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch>CHEBI:33385</skos:exactMatch>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011117">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">lawrencium atom</rdfs:label>
    <skos:exactMatch>CHEBI:33397</skos:exactMatch>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010435">
    <rdfs:label xml:lang="en">inhibitor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010436"/>
    <dcterms:description xml:lang="en">A molecular inhibitor is a molecular regulator that realizes its disposition to conformationally change a target molecule and decrease its functionality.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010033">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A hydrogen bond is a weak submolecular interaction formed between a hydrogen atom and a electronegative atom.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010005"/>
    <rdfs:label xml:lang="en">hydrogen bond</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011110">
    <rdfs:label xml:lang="en">curium atom</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <skos:exactMatch>CHEBI:33390</skos:exactMatch>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011111">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">berkelium atom</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <skos:exactMatch>CHEBI:33391</skos:exactMatch>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010042">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001381"/>
    <dcterms:description xml:lang="en">A haplotype is one of a set of genomic sequence variants.</dcterms:description>
    <rdfs:label xml:lang="en">haplotype</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010782">
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_010783"/>
    <rdfs:label xml:lang="en">heterocyclic ring</rdfs:label>
    <dcterms:description xml:lang="en">A heterocyclic ring is a ring containing a hetero atom.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010780"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001176">
    <rdfs:label xml:lang="en">negative nucleic acid strand</rdfs:label>
    <dcterms:description xml:lang="en">The negative nucleic acid strand is the strand that is that is complimentary to the forward strand and appears from 3' to 5'.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001174"/>
    <dcterms:alternative xml:lang="en">reverse strand</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000605">
    <rdfs:label xml:lang="en">sound wave</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000650"/>
    <dcterms:description xml:lang="en">A sound wave is a mechanical wave that is an oscillation of pressure transmitted through a solid, liquid, or gas, composed of frequencies within the range of hearing.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
alison callahan
leonid chepelev
kevin cohen
melanie courtot
geraint duck
laura furlong
elisa kendall
tatsuya kushida
luke mccarthy
jim mccusker
jose miguel cruz-toledo
chris mungall
robert hoehndorf
simon jupp
jin-dong kim
dana klassen
thomas luetteke
james malone
chris mungall
david osumi-sutherland
tazro ohta
nuria queralt
stephen reed
alexandre riazanov
matthias samwald
robert stevens
mark wilkinson
karin verspoor
natalia villanueva-rosales</dc:contributor>
    <dc:creator xml:lang="en">Michel Dumontier</dc:creator>
    <dcterms:creator rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://orcid.org/0000-0003-4727-9435</dcterms:creator>
    <dcterms:description xml:lang="en">The semanticscience integrated ontology (SIO) provides a simple, integrated ontology (types, relations) for objects, processes and their attributes.

This project provides foundational support for the Bio2RDF (http://bio2rdf.org) and SADI (http://sadiframework.org) projects. 

website: http://semanticscience.org
email: sio-ontology@googlegroups.com
mailing list: http://groups.google.com/group/sio-ontology
</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2010-03-29</dcterms:issued>
    <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:rights>free to use,share,modify. modify with attribution [http://creativecommons.org/licenses/by/4.0/].</dcterms:rights>
    <dcterms:title xml:lang="en">Semanticscience Integrated Ontology (SIO)</dcterms:title>
    <ns2:citesAsAuthority rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.jbiomedsem.com/content/5/1/14</ns2:citesAsAuthority>
    <vann:preferredNamespacePrefix xml:lang="en">sio</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>http://semanticscience.org/resource/</vann:preferredNamespaceUri>
    <ns3:comment>general class inclusion axioms:
'is part of' some 'physical entity' subClassOf 'is located in' some 'physical entity'

role chains:
'has capability' o 'is realized in' -&gt; 'is participant in'</ns3:comment>
    <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://sio.semanticscience.org</rdfs:seeAlso>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-01</dcterms:modified>
    <dc:identifier>sio.owl</dc:identifier>
    <owl:versionInfo>sio-subset-chemical.owl</owl:versionInfo>
    <owl:versionIRI rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011017">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <skos:exactMatch>CHEBI:49475</skos:exactMatch>
    <rdfs:label xml:lang="en">argon atom</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011065">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch>CHEBI:25195</skos:exactMatch>
    <rdfs:label xml:lang="en">mercury atom</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001379">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010471"/>
    <rdfs:label xml:lang="en">protein domain</rdfs:label>
    <dc:description xml:lang="en">A protein domain is a part of a protein that maintains its structure and function independently of the rest of the protein.</dc:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011115">
    <skos:exactMatch>CHEBI:33395</skos:exactMatch>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">mendelevium atom</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010456">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010004"/>
    <dcterms:description xml:lang="en">An ion is an atom or molecule in which the total number of electrons is not equal to the total number of protons, giving it a net positive or negative electrical charge.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001228">
    <dcterms:description xml:lang="en">A small nuclear RNA (snRNA) gene is a gene that encodes a small niuclear RNA molecule.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000790"/>
    <rdfs:label xml:lang="en">small nuclear RNA (snRNA) gene</rdfs:label>
    <ns1:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://purl.obolibrary.org/obo/SO_0001268</ns1:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010437">
    <dcterms:description xml:lang="en">A signal transducer is a molecule that responds to and amplifies a signal in a signalling system.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011125"/>
    <rdfs:label xml:lang="en">signal transducer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010419">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_011125"/>
    <rdfs:label xml:lang="en">antigen</rdfs:label>
    <dcterms:description xml:lang="en">An antigen is a molecule that can be bound by a major histocompatibility complex (MHC) and presented to a T-cell receptor.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_011106">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010044"/>
    <rdfs:label xml:lang="en">uranium atom</rdfs:label>
    <skos:exactMatch>CHEBI:27214</skos:exactMatch>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010085">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010444"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">gene regulatory component</rdfs:label>
    <dcterms:description xml:lang="en">A gene regulatory component is a gene component that exerts a regulatory function.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010783">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010780"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A homocyclic ring is a ring where the atoms are of a single type.</dcterms:description>
    <rdfs:label xml:lang="en">homocyclic ring</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010005">
    <rdfs:label xml:lang="en">weak submolecular component</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_010047"/>
    <dcterms:description xml:lang="en">A weak submolecular component is a submolecular component that weakly connects submolecular components.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010020"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010453">
    <dcterms:description xml:lang="en">An acid is a molecular entity in solution capable of donating a hydron (Bronsted acid) or capable of forming a covalent bond with an electron pair (Lewis acid).</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010427"/>
    <rdfs:label xml:lang="en">acid</rdfs:label>
