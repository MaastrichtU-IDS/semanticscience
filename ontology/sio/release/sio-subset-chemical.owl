    <rdfs:label xml:lang="en">device</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000986">
    <rdfs:label xml:lang="en">functional rna coding gene</rdfs:label>
    <dcterms:description xml:lang="en">A gene that codes for a functional RNA molecule.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010101"/>
