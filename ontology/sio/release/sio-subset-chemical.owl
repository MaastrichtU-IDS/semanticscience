    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010437"/>
    <dcterms:description xml:lang="en">A receptor molecule is a molecule that has the capability to bind to a signal and propogate a response to that signal.</dcterms:description>
