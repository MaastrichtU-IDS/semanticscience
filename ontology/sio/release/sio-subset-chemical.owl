    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010775"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">enantiomer</rdfs:label>
    <dcterms:description xml:lang="en">An enantiomer is a stereoisomer that is a mirror image of its isomer.</dcterms:description>
