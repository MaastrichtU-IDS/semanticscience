  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001393">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010471"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">post-translational modification</rdfs:label>
    <dc:description xml:lang="en">a post-translational modification is a part of a protein that was added, removed, or modified as a result of a chemical reaction after synthesis.</dc:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010092">
