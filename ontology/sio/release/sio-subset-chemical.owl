  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001235">
    <rdfs:label xml:lang="en">non-protein coding RNA (ncRNA)</rdfs:label>
    <dcterms:description xml:lang="en">A non-protein coding RNA (ncRNA) is a RNA molecular that cannot be used as a template for generating a protein product.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010450"/>
