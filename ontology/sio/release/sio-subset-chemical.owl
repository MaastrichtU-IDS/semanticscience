  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001227">
    <dcterms:description xml:lang="en">A small cytoplasmic RNA (scRNA) gene is a gene that encodes a small (7S; 129 nucleotides) RNA molecule found in the cytosol and rough endoplasmic reticulum that are normally associated with proteins that are involved in specific selection and transport of other proteins.</dcterms:description>
    <rdfs:label xml:lang="en">small cytoplasmic RNA (scRNA) gene</rdfs:label>
    <ns1:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://purl.obolibrary.org/obo/SO_0001266</ns1:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
