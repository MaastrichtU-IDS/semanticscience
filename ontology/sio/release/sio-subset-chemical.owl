  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010443">
    <dcterms:description xml:lang="en">An intron is a region of a gene that is removed from the final protein open reading frame.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
