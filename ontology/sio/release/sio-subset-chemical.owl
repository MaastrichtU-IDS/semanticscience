    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An aromatic bond is an interaction between a set of atoms across which pairs of electrons are shared.</dcterms:description>
    <rdfs:label xml:lang="en">aromatic bond</rdfs:label>
