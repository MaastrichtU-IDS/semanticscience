    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001427"/>
    <dcterms:description xml:lang="en">A polypeptide is an organic polymer composed of amino acid residues, typically of less than 50 amino acids in length.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
