    <rdfs:label xml:lang="en">optical isomer</rdfs:label>
    <dcterms:description xml:lang="en">An optical isomer is a stereoisomer that rotates the plane of polarization of a beam of plane polarized light.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
