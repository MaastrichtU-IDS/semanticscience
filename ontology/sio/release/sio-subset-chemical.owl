    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010786"/>
    <rdfs:label xml:lang="en">glassy carbon</rdfs:label>
    <dcterms:description xml:lang="en">glassy carbon is an allotrope of carbon which is widely used as an electrode material in electrochemistry, as well as for high temperature crucibles and as a component of some prosthetic devices.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010007">
    <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_010008"/>
