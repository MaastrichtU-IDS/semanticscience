    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010099"/>
    <dcterms:description xml:lang="en">An mRNA splice variant is an mRNA molecule that varies from another mRNA molecule of the same gene origin but having a different final sequence due to differences in its assembly from splice sites.</dcterms:description>
