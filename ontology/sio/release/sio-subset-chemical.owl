    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010462"/>
    <dcterms:description xml:lang="en">A sample is a limited quantity of something (e.g. an individual or set of individuals from a population, or a portion of a substance) to be used for testing, analysis, inspection, investigation, demonstration, or trial use.</dcterms:description>
