  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010791">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010786"/>
    <rdfs:label xml:lang="en">amorphous carbon</rdfs:label>
    <dcterms:description xml:lang="en">amorphous carbon is an allotrope of carbon that does not have any crystalline structure. As with all glassy materials, some short-range order can be observed, but there is no long-range pattern of atomic positions.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000314">
