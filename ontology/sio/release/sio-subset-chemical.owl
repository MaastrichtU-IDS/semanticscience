    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010462"/>
    <rdfs:label xml:lang="en">placebo</rdfs:label>
    <dcterms:description xml:lang="en">A placebo is a medically ineffectual treatment for a medical condition intended to deceive the recipient.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-chemical.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010035">
