<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://purl.org/spar/cito/"
   xmlns:ns2="http://schema.org/"
   xmlns:ns3="http://semanticscience.org/resource/"
   xmlns:ns4="http://protege.stanford.edu/plugins/owl/protege#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000631">
    <rdfs:label xml:lang="en">references</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <dcterms:description xml:lang="en">references is a relation between one entity and the entity that it makes reference to by name, but is not described by it.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:alternative>mentions</dcterms:alternative>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001277">
    <rdfs:label xml:lang="en">has data item</rdfs:label>
    <dcterms:description>has data item is a relation between a dataset and any described / referrenced entity.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <ns3:subset>core</ns3:subset>
    <owl:inverseOf rdf:resource="http://semanticscience.org/resource/SIO_001278"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000313">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is component part of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000310"/>
    <dcterms:description xml:lang="en">is component part of is a relation between a component and a whole, where the component is instrinsic to the whole, and loss of the part would change the kind that the whole is.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000628">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:subset>nlp+</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">refers to is a relation between one entity and the entity that it makes reference to.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:label xml:lang="en">refers to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000139">
    <ns3:equivalentTo>OBO_REL:has_agent</ns3:equivalentTo>
    <dcterms:description xml:lang="en">has agent is a relation between a process and an entity, where the entity is present throughout the process and is a causal participant in the process.</dcterms:description>
    <rdfs:label xml:lang="en">has agent</rdfs:label>
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000272">
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">is variant of: a relationship indicating that two entities are different (by some measure), but either achieve the same objectives in different ways or are permutations of one another (temporal, logical or otherwise)</dcterms:description>
    <rdfs:label xml:lang="en">is variant of</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000736"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000300">
    <ns3:subset xml:lang="en">sadi</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>relations</ns3:subset>
    <ns3:subset>nlp</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <dcterms:description xml:lang="en">A relation between a informational entity and its actual value (numeric, date, text, etc).</dcterms:description>
    <rdfs:label xml:lang="en">has value</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001278">
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is data item in</rdfs:label>
    <dcterms:description>'is data item in' is a relation between an entity that is described or referenced in a dataset.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000593">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">interacting is a process characterized by the interaction between two or more entities.</dcterms:description>
    <rdfs:label xml:lang="en">interacting</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000736">
    <dcterms:description xml:lang="en">is comparable to is a relation between two entities that share at least one feature whose value can be compared.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is comparable to</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000001">
    <ns2:comment>'is related to' is the top level relation in SIO</ns2:comment>
    <ns3:subset>core</ns3:subset>
    <ns3:subset>relations+</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
    <rdfs:label xml:lang="en">is related to</rdfs:label>
    <rdfs:domain rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
    <dcterms:description xml:lang="en">A is related to B iff there is some relation between A and B.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000570">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">movement is the process in which an object is spatially displaced.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">movement</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000614">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">attribute</rdfs:label>
    <dcterms:description xml:lang="en">An attribute is a characteristic of some entity.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000687">
    <dcterms:description xml:lang="en">exists at is a relation between an entity and a time measurement.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">exists at</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000355">
    <rdfs:label xml:lang="en">realizes</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">realizes is a relation between a process and a realizable entity (role, function, disposition).</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000221">
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">has unit is a relation between a quantity and the unit it is a multiple of.</dcterms:description>
    <rdfs:label xml:lang="en">has unit</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000243">
    <rdfs:label xml:lang="en">is causally related with</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000322"/>
    <dcterms:description xml:lang="en">A transitive, symmetric, temporal relation in which one entity is causally related with another non-identical entity.</dcterms:description>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000216">
    <dcterms:description xml:lang="en">has measurement value is a relation between a quality/realizable and a measurement value.</dcterms:description>
    <rdfs:label xml:lang="en">has measurement value</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000008">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000001"/>
    <rdfs:label xml:lang="en">has attribute</rdfs:label>
    <rdfs:domain rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
    <ns3:subset>core</ns3:subset>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000004">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">material entity</rdfs:label>
    <ns3:subset>core</ns3:subset>
    <dcterms:description xml:lang="en">A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-core.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
