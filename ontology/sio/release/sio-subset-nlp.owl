  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000237">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000179"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A namespace label is a short name for a namespace.</dcterms:description>
    <rdfs:label xml:lang="en">namespace label</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000315">
    <rdfs:label xml:lang="en">functional specification</rdfs:label>
    <dcterms:description xml:lang="en">A functional specification is a specification that describes the characteristics of an object.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000090"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000111">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000171"/>
    <dcterms:description xml:lang="en">A document section is a component of a document.</dcterms:description>
    <rdfs:label xml:lang="en">document section</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001391">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000621"/>
    <rdfs:label xml:lang="en">ontology</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dc:description xml:lang="en">an ontology is a formal specification of entities, their attributes and relationships.</dc:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000120">
    <rdfs:label xml:lang="en">scientific name</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000116"/>
    <dcterms:description xml:lang="en">A scientific name is a name given through scientific nomenclature.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000942">
    <dcterms:description xml:lang="en">A numeric label is a number used as a label.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000179"/>
    <rdfs:label xml:lang="en">numeric label</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000076">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A plan is a set of intended actions, through which one expects to achieve a goal.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000091"/>
    <rdfs:label xml:lang="en">plan</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000972">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has last part</rdfs:label>
    <dcterms:description xml:lang="en">has last part is a proper part relation in which the part is the last of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000974"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001324">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001319"/>
    <rdfs:label xml:lang="en">work phone number</rdfs:label>
    <dcterms:description>a work phone number is the number to connect to an phone at a place of work.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000189">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An acknowledgements section is a document section that identifies individuals, groups or organizations for their support in the development of the work.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000111"/>
    <rdfs:label xml:lang="en">acknowledgements section</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000683">
    <rdfs:label xml:lang="en">justification</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000256"/>
    <dcterms:description xml:lang="en">A justification is a proposition that defends, explains or excuses some argument.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010082">
    <skos:example xml:lang="en">RNA is translated into Protein</skos:example>
    <skos:example xml:lang="en">a relation between two information content entities in which one is translated into (a completely different kind of entity) another through some process.</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_010078"/>
    <rdfs:label xml:lang="en">is translated into</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000306">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000148"/>
    <rdfs:label xml:lang="en">letter</rdfs:label>
    <dcterms:description xml:lang="en">A letter is a document that contains a personal communication from one part to another.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000774">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is refuted by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000772"/>
    <dcterms:description xml:lang="en">has evidence is a relation between a proposition and something that refutes (is incompatible with) the truth of the assertion.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000304">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000148"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">email</rdfs:label>
    <dcterms:description xml:lang="en">Email message is a digital document that is composed of a header and a body and is transmitted using the SMTP protocol.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000731">
    <rdfs:label xml:lang="en">informational entity identifier</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000115"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">An informational entity identifier is an identifier for an informational entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000194">
    <dcterms:description xml:lang="en">A correspondence section is a document section that contains the details for contacting the corresponding author.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000111"/>
    <rdfs:label xml:lang="en">correspondence section</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000190">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000111"/>
    <dcterms:description xml:lang="en">An author contribution section is a document section that describes the contribution of the authors.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">author contribution section</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001017">
    <rdfs:label xml:lang="en">syndrome</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000136"/>
    <dcterms:description xml:lang="en">A syndrome is composed of a set of several clinically recognizable features, signs (observed by someone other than the patient), symptoms (reported by the patient), phenomena or characteristics that often occur together.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000675">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000115"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">unique identifier</rdfs:label>
    <dcterms:description xml:lang="en">A unique identifier is an identifier that uniquely identifies some thing.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000971">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000974"/>
    <rdfs:label xml:lang="en">has first part</rdfs:label>
    <dcterms:description xml:lang="en">has first part is a proper part relation in which the part is the first of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000668">
    <ns3:subset>core</ns3:subset>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000628"/>
    <rdfs:label xml:lang="en">in relation to</rdfs:label>
    <dcterms:description xml:lang="en">in relation to is a comparative relation to indicate that the instance of the class holding the relation exists in relation to another entity.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001079">
    <rdfs:label xml:lang="en">genotype</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A genotype is a functional specification of a biological entity in terms of its genetic composition (or lack thereof).</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000315"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000114">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language.</dcterms:description>
    <rdfs:label xml:lang="en">word</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001387">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001386"/>
    <rdfs:label xml:lang="en">InCHI notation</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001255">
    <dcterms:description xml:lang="en">a pharmacokinetic pathway is a metabolic pathway which describes the metabolism of a drug molecule.</dcterms:description>
    <rdfs:label xml:lang="en">pharmacokinetic pathway</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010532"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000273">
    <rdfs:label xml:lang="en">has direct part</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has direct part is a relation to specify a part at a particular level of granularity</dcterms:description>
    <skos:example xml:lang="en">a car has an engine as a direct part</skos:example>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000143">
    <dcterms:description xml:lang="en">An exclusion criterion is a criterion that must be absent to satistify the objective.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000141"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">exclusion criterion</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001196">
    <dcterms:description xml:lang="en">history is a sequence of past events.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">history</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000136"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000470">
    <rdfs:label xml:lang="en">primary title</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000185"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A primary title is a title that should be first used in describing some entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000621">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A formal specification is a mathematical description of software or hardware that may be used to develop an implementation.</dcterms:description>
    <rdfs:label xml:lang="en">formal specification</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000315"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000198">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000111"/>
    <rdfs:label xml:lang="en">materials section</rdfs:label>
    <dcterms:description xml:lang="en">The materials section is a document section containing a description of the materials used in the study.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000493">
    <rdfs:label xml:lang="en">clause</rdfs:label>
    <dcterms:description xml:lang="en">A clause consists of a subject and a predicate.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000113"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000483">
    <dcterms:description xml:lang="en">A phrase is a group of words functioning as a single unit in the syntax of a sentence.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
    <rdfs:label xml:lang="en">phrase</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000705">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A specification of an object, manifested by an agent, intended to accomplish goals, in a particular environment, using a set of primitive components, satisfying a set of requirements, subject to constraints.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000315"/>
    <rdfs:label xml:lang="en">design</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000913">
    <dcterms:description xml:lang="en">A nominal scale of measurement only specifies a limited set of categories.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000912"/>
    <rdfs:label xml:lang="en">nomimal scale</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000078">
    <ns3:subset>nlp+</ns3:subset>
    <rdfs:label xml:lang="en">language entity</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A language entity implements some language specification for the visual interpretation and is part of some document.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001031">
    <dcterms:description xml:lang="en">A minor version number is a version of a software that exhibits minor features or significant fix from a prior version.</dcterms:description>
    <rdfs:label xml:lang="en">minor version number</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000654"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000116">
    <dcterms:description xml:lang="en">A name is a label used to identify an entity.</dcterms:description>
    <rdfs:label xml:lang="en">name</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000179"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000179">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">label</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000275"/>
    <dcterms:description xml:lang="en">a label is a term that is associated with some entity</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000164">
    <dcterms:description xml:lang="en">A technical report is a publication published by a school or other institution, usually numbered within a series.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000087"/>
    <rdfs:label xml:lang="en">technical report</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000299">
    <rdfs:label xml:lang="en">quote</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000298"/>
    <dcterms:description xml:lang="en">A quote is a excerpt that is attributed to a particular source.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000979">
    <rdfs:label xml:lang="en">vowel</rdfs:label>
    <dcterms:description xml:lang="en">A vowel is a verbal entity of language that is pronounced with an open vocal tract so that there is no build-up of air pressure at any point above the glottis.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000786"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001389">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dc:description xml:lang="en">The HGVS (human genome variation society) notation is a notation to specify a sequence variation in dna, rna, proteins, and other biomolecules.</dc:description>
    <rdfs:label xml:lang="en">hgvs notation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001388"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001030">
    <rdfs:label xml:lang="en">major version number</rdfs:label>
    <dcterms:description xml:lang="en">A major version number is a version of a software that exhibits a significant change in functionalilty from a prior version.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000654"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000912">
    <rdfs:label xml:lang="en">measurement scale</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000315"/>
    <dcterms:description xml:lang="en">A measurement scale is a functional specification that specifies an allowed range of categories or values.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
</rdf:RDF>
