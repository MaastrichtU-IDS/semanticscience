    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000915"/>
    <rdfs:label xml:lang="en">decimal scale</rdfs:label>
    <dcterms:description xml:lang="en">A decimal scale of measurement is one that only specifies decimal values.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001319">
    <rdfs:label xml:lang="en">telephone number</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000731"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
