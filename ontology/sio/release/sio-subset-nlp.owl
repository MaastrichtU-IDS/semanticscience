  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010528">
    <dcterms:description xml:lang="en">A chemical degradation pathway is a pathway involved in the disassembly of a chemical.</dcterms:description>
    <rdfs:label xml:lang="en">chemical degradation pathway</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010526"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000054">
    <skos:example xml:lang="en">the surface of an apple is a 2D boundary of the apple.</skos:example>
    <rdfs:label xml:lang="en">has boundary</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has boundary is a mereological relation between a whole and boundary located at its periphery.</dcterms:description>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
