>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000091">
    <dcterms:alternative>effective specification</dcterms:alternative>
    <rdfs:label xml:lang="en">action specification</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000090"/>
    <dcterms:description xml:lang="en">An action specification is a specification composed of a sequence of instructions to achieve some objective.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001075">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000732"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A microarray probe set identifier is an identifier for a set of probe pairs selected to represent expressed sequences on an array. </dcterms:description>
    <rdfs:label xml:lang="en">microarray probe set identifier</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000020">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000210"/>
    <rdfs:label xml:lang="en">denotes</rdfs:label>
    <skos:example xml:lang="en">the symbol '%' denotes a proportion in relation to a whole.</skos:example>
    <dcterms:description xml:lang="en">denotes is a relation between an entity and what it is a sign or indication of, or what specifically means.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000332">
    <dcterms:description xml:lang="en">is about is a relation between an information content entity and the entity that its primary subject.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000563"/>
    <rdfs:label xml:lang="en">is about</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000126">
    <dcterms:description xml:lang="en">A homonym is a word that sounds the same but has different meaning.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000342"/>
    <rdfs:label xml:lang="en">homonym</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001331">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">diagnosis</rdfs:label>
    <dcterms:description xml:lang="en">A diagnosis is the result of a medical investigation to identify a disorder from its signs and symptoms.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000262"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000155">
    <dcterms:description xml:lang="en">A blog is a publication accessible at some website and is typically about various experiences.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000087"/>
    <rdfs:label xml:lang="en">blog</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010525">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_010526"/>
    <rdfs:label xml:lang="en">biochemical pathway</rdfs:label>
    <dcterms:description xml:lang="en">A biochemical pathway specifies a series of biochemical modifications and transformations towards achieving some biological outcome.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010032">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000729"/>
    <dcterms:description xml:lang="en">A PDB record identifier is an identifier for a PDB generated record.</dcterms:description>
    <rdfs:label xml:lang="en">PDB record identifier</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000771">
    <dcterms:description xml:lang="en">A versioned record is a record for which there exists another variant based that was derived via modification of the facts.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000088"/>
    <rdfs:label xml:lang="en">versioned record</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000109">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A novel is a fictitious prose narrative of book length, typically representing character and action with some degree of realism.</dcterms:description>
    <rdfs:label xml:lang="en">novel</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000087"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000328">
    <dcterms:description xml:lang="en">A positional description is a description of location using some system or frame of reference.</dcterms:description>
    <rdfs:label xml:lang="en">positional identifier</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000115"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000135">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:description xml:lang="en">A definition is a description that succintly characterizes an entity.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000136"/>
    <rdfs:label xml:lang="en">definition</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_001317">
    <rdfs:label xml:lang="en">middle name</rdfs:label>
    <dcterms:description>a middle name is a name assigned to an individual that is not the first or last name.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000116"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000728">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000730"/>
    <dcterms:description xml:lang="en">A chemical identifier is an identifier for a chemical entity</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">chemical identifier</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000147">
    <dcterms:description xml:lang="en">A keyword is a descriptor in which the association of the word with the entity facilitates information retrieval.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">keyword</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000133"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000772">
    <rdfs:subPropertyOf rdf:resource="http://semanticscience.org/resource/SIO_000631"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcterms:description xml:lang="en">has evidence is a relation between a proposition and something that demonstrates the truth of the assertion.</dcterms:description>
    <rdfs:label xml:lang="en">has evidence</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000204">
    <ns3:equivalentTo>OBO_REL:adjacent_to</ns3:equivalentTo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <ns3:subset>nlp</ns3:subset>
    <ns3:subset>core</ns3:subset>
    <rdfs:label xml:lang="en">is adjacent to</rdfs:label>
    <dcterms:description xml:lang="en">A is adjacent to B iff there is a small, but non-zero distance between A and B</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000088">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">record</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000148"/>
    <dcterms:description xml:lang="en">A record is a document containing a collection of statements about some entity.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000180">
    <dcterms:description xml:lang="en">A language label is a label that denotes the language of a textual entity.</dcterms:description>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000179"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">language label</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000124">
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000342"/>
    <dcterms:description xml:lang="en">A hypernym is a term with a broader meaning.</dcterms:description>
    <rdfs:label xml:lang="en">hypernym</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000172">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">address</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000328"/>
    <dcterms:description xml:lang="en">An address is a position that indicates the physical location of some entity using a social convention.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000152">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">note</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000148"/>
    <dcterms:description xml:lang="en">A note is a brief document.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/ontology/sio.owl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <ns4:defaultLanguage>en</ns4:defaultLanguage>
    <dc:contributor>Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
alison callahan
leonid chepelev
kevin cohen
melanie courtot
geraint duck
laura furlong
