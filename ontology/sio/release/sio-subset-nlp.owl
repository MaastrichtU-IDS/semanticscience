  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_010053">
    <dcterms:description xml:lang="en">evolutionary lineage is a sequence of species, that form a line of descent, each new species the direct result of speciation from an immediate ancestral species.</dcterms:description>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_001196"/>
    <rdfs:label xml:lang="en">evolutionary lineage</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio/v1.61/sio-subset-nlp.owl"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000265">
    <dcterms:description xml:lang="en">A sound argument is a valid argument with true premises.</dcterms:description>
    <rdfs:label xml:lang="en">sound argument</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000266"/>
